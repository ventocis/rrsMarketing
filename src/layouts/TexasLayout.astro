---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  url?: string;
  banner?: string;
  showPromo?: boolean;
}

const {
  title,
  description = 'The easiest way to dismiss your Texas traffic ticket. TDLR-approved, all courts accepted.',
  keywords = 'Texas driver safety course, defensive driving, traffic school, online course, Texas approved',
  url = '/texas',
  banner = '$28 Total, No Hidden Fees — No Surprises at Checkout',
  showPromo = true,
} = Astro.props;

const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '#';
const loginUrl = import.meta.env.VITE_LOGIN_URL || '#';
const currentYear = new Date().getFullYear();
---

<Layout title={title} description={description} keywords={keywords} url={url}>
  <!-- JSON-LD: Texas Defensive Driving Course -->
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Texas 6-Hour Defensive Driving Course",
        "description": "TDLR-approved online Texas Driver Safety Course. Complete your 6-hour course to dismiss a traffic ticket or reduce auto insurance rates. Accepted by all Texas courts.",
        "url": "https://roadreadysafety.com/texas",
        "provider": {
          "@type": "Organization",
          "name": "Road Ready Safety",
          "url": "https://roadreadysafety.com",
          "logo": "https://roadreadysafety.com/assets/icons/texas/logo-shield.svg"
        },
        "courseMode": "online",
        "educationalCredentialAwarded": "TDLR Certificate of Completion",
        "timeRequired": "PT6H",
        "inLanguage": "en-US",
        "isAccessibleForFree": false,
        "offers": {
          "@type": "Offer",
          "price": "28",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": "https://roadreadysafety.com/texas"
        },
        "hasCourseInstance": {
          "@type": "CourseInstance",
          "courseMode": "online",
          "courseSchedule": {
            "@type": "Schedule",
            "repeatFrequency": "P1D",
            "repeatCount": -1
          }
        }
      }
    </script>
  </Fragment>

  <!-- Announcement Banner -->
  {showPromo ? (
    <div id="promo-banner" class="bg-announcement-tx text-white text-center py-2.5 px-4" style="font-family: 'DM Sans', sans-serif;">

      <!-- Desktop: single row -->
      <div class="hidden sm:flex items-center justify-center gap-2.5">
        <span class="text-sm font-semibold leading-5">Limited Time: Use code</span>
        <code class="text-xs font-bold tracking-widest bg-white/20 border border-white/30 rounded px-2 py-0.5" style="font-family: 'DM Mono', 'Courier New', monospace;">TAKE3</code>
        <span class="text-sm font-semibold leading-5">and pay only $25.</span>
        <span class="text-white/50">·</span>
        <span class="text-sm font-medium leading-5 text-white/80">Ends in</span>
        <span id="promo-countdown" class="inline-flex items-center gap-1.5 text-xs font-bold tabular-nums">
          <span class="flex flex-col items-center leading-none"><span id="cd-d">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">days</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-h">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">hrs</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-m">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">min</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-s">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">sec</span></span>
        </span>
      </div>

      <!-- Mobile: two tight lines -->
      <div class="flex sm:hidden flex-col items-center gap-1">
        <div class="flex items-center gap-1.5">
          <span class="text-xs font-semibold leading-4">Use code</span>
          <code class="text-[11px] font-bold tracking-widest bg-white/20 border border-white/30 rounded px-1.5 py-0.5" style="font-family: 'DM Mono', 'Courier New', monospace;">TAKE3</code>
          <span class="text-xs font-semibold leading-4">— pay only $25. Ends in:</span>
        </div>
        <span id="promo-countdown-mobile" class="inline-flex items-center gap-2 text-xs font-bold tabular-nums">
          <span class="flex flex-col items-center leading-none"><span id="cd-d-m">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">days</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-h-m">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">hrs</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-m-m">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">min</span></span>
          <span class="text-white/40 mb-2">:</span>
          <span class="flex flex-col items-center leading-none"><span id="cd-s-m">--</span><span class="text-[9px] font-normal text-white/60 mt-0.5">sec</span></span>
        </span>
      </div>

    </div>
  ) : (
    <div class="bg-announcement-tx text-white text-sm font-semibold text-center py-3 px-4 leading-5">
      {banner}
    </div>
  )}

  <script>
    var _promoInterval: ReturnType<typeof setInterval> | null = null;

    function initPromoCountdown() {
      // Clear any previous interval from a prior page load
      if (_promoInterval !== null) {
        clearInterval(_promoInterval);
        _promoInterval = null;
      }

      var banner = document.getElementById('promo-banner');
      if (!banner) return; // showPromo is false on this page — nothing to do

      // June 1 2026 00:00:00 CST = UTC-6 = June 1 2026 06:00:00 UTC
      var deadline = new Date('2026-06-01T06:00:00Z').getTime();

      var elD  = document.getElementById('cd-d');
      var elH  = document.getElementById('cd-h');
      var elM  = document.getElementById('cd-m');
      var elS  = document.getElementById('cd-s');
      var elDm = document.getElementById('cd-d-m');
      var elHm = document.getElementById('cd-h-m');
      var elMm = document.getElementById('cd-m-m');
      var elSm = document.getElementById('cd-s-m');

      function pad(n: number) { return n < 10 ? '0' + n : '' + n; }

      function tick() {
        var now = Date.now();
        var diff = deadline - now;
        if (diff <= 0) {
          if (banner) banner.innerHTML = '<p class="text-sm font-semibold leading-5 text-center" style="font-family:\'DM Sans\',sans-serif;">$28 Total, No Hidden Fees — No Surprises at Checkout</p>';
          if (_promoInterval !== null) clearInterval(_promoInterval);
          return;
        }
        var days = Math.floor(diff / 86400000);
        var hrs  = Math.floor((diff % 86400000) / 3600000);
        var mins = Math.floor((diff % 3600000) / 60000);
        var secs = Math.floor((diff % 60000) / 1000);
        if (elD)  elD.textContent  = pad(days);
        if (elH)  elH.textContent  = pad(hrs);
        if (elM)  elM.textContent  = pad(mins);
        if (elS)  elS.textContent  = pad(secs);
        if (elDm) elDm.textContent = pad(days);
        if (elHm) elHm.textContent = pad(hrs);
        if (elMm) elMm.textContent = pad(mins);
        if (elSm) elSm.textContent = pad(secs);
      }

      tick();
      _promoInterval = setInterval(tick, 1000);
    }

    // Run on initial load (module scripts are deferred, but guard for safety).
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPromoCountdown);
    } else {
      initPromoCountdown();
    }
  </script>

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-border shadow-[0px_1px_3px_0px_rgba(17,23,34,0.04)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/texas" class="flex items-center gap-2 no-underline flex-shrink-0">
          <img src="/assets/icons/texas/logo-shield.svg" alt="Road Ready Safety" class="w-9 h-9 flex-shrink-0" />
          <div class="flex flex-col leading-none">
            <span class="text-[14px] font-bold text-primary-navy leading-tight">Road Ready</span>
            <span class="text-[10px] font-medium text-text-body leading-tight">Safety TDLR: CP#1234</span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-8">
          <a href="/texas/pricing" class="text-sm font-medium text-text-body hover:text-text no-underline transition-colors">Pricing</a>
          <a href="/texas/faq" class="text-sm font-medium text-text-body hover:text-text no-underline transition-colors">FAQ</a>
          <a href="/texas/helpcenter" class="text-sm font-medium text-text-body hover:text-text no-underline transition-colors">Help Center</a>
          <a href="/texas/eligibility-tracker" class="text-sm font-medium text-text-body hover:text-text no-underline transition-colors">Eligibility Checker</a>
        </nav>

        <!-- Desktop CTA Buttons -->
        <div class="hidden lg:flex items-center gap-3">
          <a
            href={loginUrl}
            class="h-10 px-5 border border-border text-text rounded-xl text-sm font-semibold flex items-center justify-center no-underline hover:bg-surface-muted transition-colors"
          >
            Log In
          </a>
          <a
            href={enrollUrl}
            class="h-10 px-5 bg-primary hover:bg-primary-hover text-white rounded-xl text-sm font-semibold flex items-center justify-center no-underline transition-colors shadow-[0px_4px_6px_-1px_rgba(17,23,34,0.1)]"
          >
            Start Course
          </a>
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg border border-border text-text-body hover:bg-surface-muted transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg id="icon-open" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg id="icon-close" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col gap-4">
        <a href="/texas/pricing" class="text-sm font-medium text-text-body hover:text-text no-underline py-2">Pricing</a>
        <a href="/texas/faq" class="text-sm font-medium text-text-body hover:text-text no-underline py-2">FAQ</a>
        <a href="/texas/helpcenter" class="text-sm font-medium text-text-body hover:text-text no-underline py-2">Help Center</a>
        <a href="/texas/eligibility-tracker" class="text-sm font-medium text-text-body hover:text-text no-underline py-2">Eligibility Checker</a>
        <hr class="border-border" />
        <div class="flex flex-col gap-3">
          <a
            href={loginUrl}
            class="h-10 px-5 border border-border text-text rounded-xl text-sm font-semibold flex items-center justify-center no-underline hover:bg-surface-muted transition-colors"
          >
            Log In
          </a>
          <a
            href={enrollUrl}
            class="h-10 px-5 bg-primary hover:bg-primary-hover text-white rounded-xl text-sm font-semibold flex items-center justify-center no-underline transition-colors"
          >
            Start Course
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Page Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-surface-dark text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

        <!-- Column 1: Company Info -->
        <div class="flex flex-col gap-6">
          <!-- Logo -->
          <a href="/texas" class="flex items-center gap-2 no-underline">
            <img src="/assets/icons/texas/logo-shield-footer.svg" alt="Road Ready Safety" class="w-10 h-10 flex-shrink-0" />
            <div class="flex flex-col leading-none">
              <span class="text-[14px] font-bold text-white leading-tight">Road Ready</span>
              <span class="text-[10px] font-medium text-text-subtle leading-tight">Safety</span>
            </div>
          </a>
          <p class="text-sm text-text-subtle leading-6">
            Texas's simplest TDLR-approved defensive driving course. Dismiss your ticket or reduce insurance rates — fast, easy, and online.
          </p>
          <a href="mailto:support@roadreadysafety.com" class="text-sm text-info-border hover:text-white no-underline transition-colors">
            support@roadreadysafety.com
          </a>
          <!-- TDLR Badge -->
          <div class="inline-flex items-center gap-2 bg-surface-dark rounded-full px-3 py-2 w-fit">
            <img src="/assets/icons/texas/tdlr-badge-footer.svg" alt="" class="w-4 h-4" />
            <span class="text-xs font-semibold text-info-border">TDLR Approved CP#1234</span>
          </div>
        </div>

        <!-- Column 2: Course Links -->
        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Course</h3>
          <nav class="flex flex-col gap-3">
            <a href="/texas" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Texas Defensive Driving</a>
            <a href="/texas/pricing" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Pricing</a>
            <a href="/texas/faq" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">FAQ</a>
            <a href={enrollUrl} class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Start Course</a>
          </nav>
        </div>

        <!-- Column 3: Support Links -->
        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Support</h3>
          <nav class="flex flex-col gap-3">
            <a href="/texas/helpcenter" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Help Center</a>
            <a href={import.meta.env.VITE_CONTACT_US_URL || '/contact'} class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Contact Us</a>
            <a href={loginUrl} class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Log In</a>
          </nav>
        </div>

        <!-- Column 4: Legal Links -->
        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Legal</h3>
          <nav class="flex flex-col gap-3">
            <a href="/privacy" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Privacy</a>
            <a href="/texas/terms" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Terms</a>
            <a href="/texas/refund" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Refund</a>
            <a href="/texas/accessibility" class="text-sm text-text-subtle hover:text-white no-underline transition-colors">Accessibility</a>
          </nav>
        </div>

      </div>

      <!-- Footer Bottom -->
      <div class="border-t border-surface-dark mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-muted">
          &copy; {currentYear} Road Ready Driver Instruction LLC d/b/a Road Ready Safety. All rights reserved.
        </p>
        <p class="text-xs text-text-muted">
          TDLR-Licensed Driving Safety Provider &middot; CP#1234
        </p>
      </div>
    </div>
  </footer>
</Layout>

<script>
  // Mobile menu toggle via event delegation. One listener on `document`
  // survives full page loads AND view-transition DOM swaps, so it never needs
  // rebinding and doesn't depend on the ViewTransitions router (astro:page-load).
  if (!(window as any).__rrsTexasMenuDelegated) {
    (window as any).__rrsTexasMenuDelegated = true;

    function setMenuOpen(open: boolean) {
      const menu = document.getElementById('mobile-menu');
      const btn = document.getElementById('mobile-menu-btn');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      if (!menu || !btn) return;
      menu.classList.toggle('hidden', !open);
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      btn.setAttribute('aria-expanded', String(open));
    }

    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      if (target?.closest('#mobile-menu-btn')) {
        const menu = document.getElementById('mobile-menu');
        setMenuOpen(menu?.classList.contains('hidden') ?? true);
        return;
      }
      if (target?.closest('#mobile-menu a')) {
        setMenuOpen(false);
      }
    });
  }
</script>
