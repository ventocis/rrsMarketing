---
import faqData from '../copy/faq.json';
const { heading, items } = faqData;
const visibleItems = items.slice(0, 8);

const contactUrl = import.meta.env.VITE_CONTACT_US_URL || '/support';
---

<section class="bg-surface-muted py-16 lg:py-28 border-b border-border">
  <div class="max-w-[768px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 items-center mb-12">
      <div class="bg-info inline-flex items-center px-4 py-2 rounded-full">
        <span class="text-sm font-semibold text-info-text leading-5">Got Questions?</span>
      </div>
      <h2 class="text-[28px] lg:text-[36px] font-bold text-center text-text tracking-[-0.02em] lg:tracking-[-0.9px] leading-[150%] lg:leading-[40px]">
        {heading}
      </h2>
      <p class="text-base text-center text-text-body leading-6 max-w-[672px]">Commonly Asked Questions</p>
    </div>

    <!-- Native HTML details/summary accordion — zero JS, full Lighthouse score -->
    <div class="flex flex-col gap-4 mb-12">
      {visibleItems.map((item) => (
        <details class="group bg-white border border-border rounded-[16px] overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-5 text-base font-semibold text-text tracking-[-0.4px] leading-6 cursor-pointer hover:bg-gray-50 transition-colors list-none">
            {item.q}
            <!-- Chevron icon rotates open/closed via CSS -->
            <svg class="w-5 h-5 text-text-body flex-shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 border-t border-border text-base leading-6 text-text-body">
            {Array.isArray(item.a)
              ? item.a.map((paragraph) => (
                <div set:html={paragraph} />
              ))
              : <div set:html={item.a} />
            }
          </div>
        </details>
      ))}
    </div>

    <div class="bg-white border border-border rounded-[20px] p-8 flex flex-col gap-3 items-center">
      <h3 class="text-xl font-semibold text-center text-text tracking-[-0.5px] leading-7">Still have questions?</h3>
      <p class="text-base text-center text-text-body leading-6 max-w-[672px]">Our support team is here to help.</p>
      <a
        href={contactUrl}
        class="mt-3 border border-primary-deep bg-transparent hover:bg-primary-deep hover:text-white text-primary-deep text-base font-semibold py-3 px-8 rounded-[16px] min-h-[48px] flex items-center justify-center gap-2 transition-colors"
        style="font-family: 'DM Sans', sans-serif;"
      >
        Contact Support
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Hide default details marker across browsers */
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; }
</style>
