            </details>

            <!-- Step 5 -->
            <details class="bg-white border border-border rounded-2xl overflow-hidden shadow-sm group">
              <summary class="px-8 py-6 flex items-center gap-4 cursor-pointer list-none hover:bg-gray-50 transition-colors">
