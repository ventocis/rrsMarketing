---
import DocLayout from '../../layouts/DocLayout.astro';
import { marked } from 'marked';
import { readFileSync } from 'fs';
import { join } from 'path';
import coursesData from '../../data/courses.json';
import { stateNames } from '../../utils/states';

const md = readFileSync(join(process.cwd(), 'src/content/docs/how-to-submit.md'), 'utf-8');
const html = marked(md);

// Group courses by state for the state requirements section (built at static time)
const grouped: Record<string, typeof coursesData> = {};
for (const course of coursesData) {
  if (!grouped[course.state]) grouped[course.state] = [];
  grouped[course.state].push(course);
}
const coursesByState = Object.entries(grouped).sort(([a], [b]) =>
  (stateNames[a] || a).localeCompare(stateNames[b] || b)
);
---

<DocLayout
  title="How to Submit Your Certificate"
  description="Learn when and how to submit your traffic course completion certificate to the court or DMV."
  keywords="certificate submission, traffic course certificate, DMV submission, court submission"
  url="/support/how-to-submit"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Help Center', href: '/support' },
    { label: 'How to Submit' }
  ]}
>
  <Fragment set:html={html} />

  <!-- State course requirements — pure static, no JS needed -->
  <div class="mt-8 not-prose">
    <h3 class="text-xl font-bold text-text mb-4" style="font-family: 'Outfit', sans-serif;">
      Course Requirements by State
    </h3>
    <p class="text-sm text-text-body mb-4" style="font-family: 'DM Sans', sans-serif;">
      Click your state for detailed requirements:
    </p>
    <div class="space-y-2">
      {coursesByState.map(([stateCode, courses]) => (
        <details class="border border-border rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between px-4 py-3 bg-surface-muted hover:bg-gray-100 cursor-pointer list-none text-sm font-medium text-text transition-colors">
            {stateNames[stateCode] || stateCode} ({courses.length})
            <svg class="w-4 h-4 text-text-body transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 py-3 border-t border-border bg-white space-y-1">
            {courses.map((course) => (
              <a
                href={`/courses/${course.slug}/requirements`}
                class="block text-sm text-primary hover:text-primary-hover hover:underline leading-tight py-0.5"
              >
                {course.course_name}
              </a>
            ))}
          </div>
        </details>
      ))}
    </div>
  </div>
</DocLayout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; }
</style>
