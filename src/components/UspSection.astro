---
import homeData from '../copy/home.json';
const { heading, items } = homeData.usp;

const icons = [
  // Clock — Learn on your schedule
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
  // Check-circle — Satisfaction guarantee
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`,
  // Zap — Shortest course
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>`,
  // Smartphone — Works on any device
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>`,
];
---

<section class="bg-surface-muted py-16 lg:py-24 border-b border-border" style="font-family: 'Inter', sans-serif;">
  <div class="max-w-[1152px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 items-center mb-12">
      <div class="bg-info inline-flex items-center px-4 py-2 rounded-full">
        <span class="text-sm font-semibold text-info-text leading-5">Why Choose Us</span>
      </div>
      <h2 class="text-[28px] lg:text-[36px] font-bold text-center text-text tracking-[-0.02em] lg:tracking-[-0.9px] leading-[150%] lg:leading-[40px]">
        {heading}
      </h2>
      <p class="text-base text-center text-text-body leading-6">
        Everything you need to complete your course with confidence.
      </p>
    </div>

    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
        {items.map((item, i) => (
          <div
            class="bg-white rounded-[12px] border border-border p-8 hover:shadow-md transition-shadow relative"
            style="box-shadow: 0px 1px 2px 0px rgba(16, 24, 40, 0.05);"
          >
            <div class="absolute top-8 right-8 text-primary" aria-hidden="true" set:html={icons[i]} />
            <h3 class="text-xl font-medium text-text mb-3 tracking-[-0.02em] pr-8" style="line-height: 30px;">
              {item.title}
            </h3>
            <p class="text-base leading-[22px] text-text-body">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
