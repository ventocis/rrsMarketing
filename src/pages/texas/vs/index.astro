---
import TexasLayout from '../../../layouts/TexasLayout.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';

const comparisons = [
  {
    slug: 'defensivedriving',
    title: 'Road Ready Safety vs DefensiveDriving.com — Texas Defensive Driving (2026)',
    description: "Both start at $28. DefensiveDriving.com charges $25 more for your certificate after you finish the course. Here's the full breakdown before you start.",
    rrsPrice: '$28',
    themPrice: '$53',
    themLabel: 'DefensiveDriving.com',
  },
  {
    slug: 'onlinetxdefensivedriving',
    title: 'Road Ready Safety vs OnlineTXDefensiveDrivingCourse.com — Texas Defensive Driving (2026)',
    description: "Both advertise $25. One charges $49.95 extra to email you your certificate. Here's the full breakdown before you pay.",
    rrsPrice: '$28',
    themPrice: '$77.95',
    themLabel: 'OnlineTXDefensiveDriving',
  },
  {
    slug: 'aceable',
    title: 'Road Ready Safety vs Aceable — Texas Defensive Driving (2026)',
    description: "Aceable is well-rated and has an app. It also costs $49–$59 all-in vs $28 at Road Ready Safety. Here's what that difference actually buys you.",
    rrsPrice: '$28',
    themPrice: '$49–$59',
    themLabel: 'Aceable',
  },
  {
    slug: 'improv',
    title: 'Road Ready Safety vs IMPROV Defensive Driving Texas (2026)',
    description: "IMPROV's course is entertaining and includes comedy club tickets. It's also $28.95 with recurring technical complaints. Here's what to know before you sign up.",
    rrsPrice: '$28',
    themPrice: '$28.95',
    themLabel: 'IMPROV',
  },
  {
    slug: 'comedydriving',
    title: 'Road Ready Safety vs Comedy Driving Texas (2026)',
    description: "Comedy Driving promises a funny defensive driving course. Reviews say it's less funny than advertised, and the certificate costs extra. Here's the full breakdown.",
    rrsPrice: '$28',
    themPrice: '$28+',
    themLabel: 'Comedy Driving',
  },
  {
    slug: 'safemotorist',
    title: 'Road Ready Safety vs SafeMotorist Texas Defensive Driving (2026)',
    description: "SafeMotorist's free certificate takes 5 days before you can download it. Instant delivery is $9.95 extra. All-in: $34.95 vs $28. Here's the full breakdown.",
    rrsPrice: '$28',
    themPrice: '$34.95',
    themLabel: 'SafeMotorist',
  },
];
---

{isEnabled ? (
  <TexasLayout
    title="Texas Defensive Driving — Provider Comparisons (2026)"
    description="Side-by-side breakdowns of Road Ready Safety vs other TDLR-approved Texas defensive driving providers. See verified all-in prices before you enroll."
    url="/texas/vs"
  >
    <section class="py-[112px] px-4 sm:px-6 lg:px-8 bg-surface-muted">
      <div class="max-w-4xl mx-auto flex flex-col gap-12">

        <!-- Header -->
        <div class="flex flex-col gap-4 items-center">
          <div class="bg-info inline-flex items-center px-4 py-2 rounded-full">
            <span class="text-sm font-semibold text-info-text leading-5" style="font-family: 'DM Sans', sans-serif;">Provider Comparisons</span>
          </div>
          <h1 class="text-[36px] font-bold text-text text-center leading-[40px] tracking-[-0.9px]" style="font-family: 'Outfit', sans-serif;">
            Road Ready Safety vs Other<br/>Texas Defensive Driving Providers
          </h1>
          <p class="text-base text-text-body text-center leading-6 max-w-2xl" style="font-family: 'DM Sans', sans-serif;">
            Most Texas defensive driving providers advertise the same $25 starting price. What you actually pay at checkout — and when you find out — varies significantly. These pages show verified all-in totals, real customer complaints, and a straight answer on who each provider is right for.
          </p>
        </div>

        <!-- Comparison cards -->
        <div class="flex flex-col gap-4">
          {comparisons.map(c => (
            <a
              href={`/texas/vs/${c.slug}`}
              class="group bg-white border border-border rounded-2xl overflow-hidden hover:border-primary hover:shadow-sm transition-all no-underline"
            >
              <div class="flex flex-col sm:flex-row">
                <!-- Price strip -->
                <div class="flex sm:flex-col items-center justify-center sm:justify-start gap-3 sm:gap-1 px-6 py-4 sm:py-5 sm:w-44 sm:border-r border-b sm:border-b-0 border-border bg-surface-muted/50 flex-shrink-0">
                  <div class="text-center">
                    <p class="text-[10px] font-semibold text-text-subtle uppercase tracking-widest mb-0.5" style="font-family: 'DM Sans', sans-serif;">Road Ready</p>
                    <p class="text-2xl font-bold text-primary leading-none" style="font-family: 'Outfit', sans-serif;">{c.rrsPrice}</p>
                  </div>
                  <span class="text-xs font-semibold text-text-subtle sm:my-1">vs</span>
                  <div class="text-center">
                    <p class="text-[10px] font-semibold text-text-subtle uppercase tracking-widest mb-0.5" style="font-family: 'DM Sans', sans-serif;">{c.themLabel}</p>
                    <p class="text-2xl font-bold text-text leading-none" style="font-family: 'Outfit', sans-serif;">{c.themPrice}</p>
                  </div>
                </div>

                <!-- Content -->
                <div class="flex flex-col justify-center gap-2 px-6 py-5 flex-1">
                  <p class="text-base font-semibold text-text leading-snug tracking-[-0.3px]" style="font-family: 'Outfit', sans-serif;">{c.title}</p>
                  <p class="text-sm text-text-body leading-6" style="font-family: 'DM Sans', sans-serif;">{c.description}</p>
                  <span class="text-sm font-semibold text-primary group-hover:underline mt-1" style="font-family: 'DM Sans', sans-serif;">
                    See full breakdown →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Crosslink block -->
        <div class="bg-white border border-border rounded-[20px] p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
          <div class="flex flex-col gap-1">
            <p class="text-base font-semibold text-text leading-6 tracking-[-0.4px]" style="font-family: 'Outfit', sans-serif;">See every TDLR-approved provider in one table</p>
            <p class="text-sm text-text-body leading-6" style="font-family: 'DM Sans', sans-serif;">Verified all-in checkout totals for 10 providers — including processing fees and certificate delivery costs.</p>
          </div>
          <a
            href="/texas/cost"
            class="h-12 px-6 border border-primary-deep text-primary-deep hover:bg-primary-deep hover:text-white rounded-2xl text-sm font-semibold inline-flex items-center justify-center gap-2 no-underline transition-colors flex-shrink-0"
            style="font-family: 'DM Sans', sans-serif;"
          >
            Compare all prices
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- CTA block — matches /texas landing page pattern -->
        <div class="bg-primary-deep rounded-[24px] px-8 lg:px-16 py-16 relative overflow-hidden">
          <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute bg-[#46a2f2] blur-[32px] rounded-full w-[384px] h-[384px] -right-48 -top-48"></div>
            <div class="absolute bg-[#46a2f2] blur-[32px] rounded-full w-[256px] h-[256px] -bottom-32 -left-32"></div>
          </div>
          <div class="relative flex flex-col gap-6 items-center max-w-lg mx-auto text-center">
            <div class="flex flex-col gap-3 items-center">
              <h2 class="text-4xl font-bold text-white leading-[1.1] tracking-[-1.2px]" style="font-family: 'Outfit', sans-serif;">
                Ready to Dismiss Your Texas Ticket?
              </h2>
              <p class="text-lg text-[#b9e2fe] leading-7" style="font-family: 'DM Sans', sans-serif;">
                Join thousands of Texas drivers who've cleared their record with Road Ready Safety — TDLR-approved, instant certificate.
              </p>
            </div>
            <a
              href={enrollUrl}
              class="w-full sm:w-auto sm:min-w-[280px] h-[60px] px-10 bg-white hover:bg-surface-muted text-primary-deep rounded-full text-[18px] font-bold flex items-center justify-center gap-2 leading-[28px] no-underline shadow-[0px_8px_24px_rgba(0,0,0,0.18)] transition-colors"
              style="font-family: 'DM Sans', sans-serif;"
            >
              Start Course — $28
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M3.5 9h11M10 4.5L14.5 9 10 13.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </section>
  </TexasLayout>
) : (
  <meta http-equiv="refresh" content="0; url=/" />
)}
