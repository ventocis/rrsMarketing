---
/**
 * DocLayout — shared layout for markdown-based pages (privacy, terms, partners, how-to-submit).
 * Renders markdown content with consistent prose styling.
 */
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  url: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, keywords, url, breadcrumbs = [] } = Astro.props;
---

<Layout title={title} description={description} keywords={keywords} url={url}>
  <Header />

  <main class="bg-white min-h-screen">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">

      {breadcrumbs.length > 0 && (
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex flex-wrap items-center gap-2 text-sm text-[#616d7b]" style="font-family: 'DM Sans', sans-serif;">
            {breadcrumbs.map((crumb, i) => (
              <li class="flex items-center gap-2">
                {i > 0 && <span aria-hidden="true">›</span>}
                {crumb.href
                  ? <a href={crumb.href} class="hover:text-[#0667D1] transition-colors">{crumb.label}</a>
                  : <span class="text-[#1e2832] font-medium">{crumb.label}</span>
                }
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Prose content injected by each page -->
      <div class="prose prose-slate max-w-none
        prose-headings:font-bold prose-headings:text-[#1e2832] prose-headings:tracking-tight
        prose-h1:text-3xl prose-h1:md:text-4xl prose-h1:mb-4
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#616d7b] prose-p:leading-7
        prose-a:text-[#0667D1] prose-a:no-underline hover:prose-a:underline
        prose-strong:text-[#1e2832]
        prose-ul:text-[#616d7b] prose-ol:text-[#616d7b]
        prose-li:leading-7
        prose-hr:border-[#e5e5e5]
      ">
        <slot />
      </div>
    </div>
  </main>

  <Footer />
</Layout>
