---
import TexasLayout from '../../../layouts/TexasLayout.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';

const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Road Ready Safety vs DefensiveDriving.com — Texas Defensive Driving (2026)',
  dateModified: '2026-05-25',
  datePublished: '2026-05-25',
  author: { '@type': 'Organization', name: 'Road Ready Safety' },
  publisher: { '@type': 'Organization', name: 'Road Ready Safety', url: siteUrl },
});

const faqs = [
  {
    q: 'Do both courses cost the same?',
    a: 'Both start at $28. Road Ready Safety is $28 all-in including the instant certificate. DefensiveDriving.com is $28 for the course, then $25 more for instant certificate delivery — $53 total. The free option from DefensiveDriving.com is standard mail with 2-plus business days of processing before USPS transit begins.',
  },
  {
    q: 'When does DefensiveDriving.com show the certificate fee?',
    a: 'Based on consistent customer reports, the certificate delivery fee is presented after course completion — not before you start or at checkout.',
  },
  {
    q: "Is DefensiveDriving.com's $250 guarantee legitimate?",
    a: 'Per their published terms, they will cover up to $250 if your ticket is not dismissed after completing their course, provided the submission was accurate, complete, and on time.',
  },
  {
    q: "What is Road Ready Safety's refund policy?",
    a: "Road Ready Safety offers a 100% refund as long as you haven't completed the course and downloaded your certificate. There's no call to make and no form to fill out — just hit the request refund button in the student portal and it's done.",
  },
  {
    q: 'Does DefensiveDriving.com offer a video course?',
    a: 'Yes. Their video course is $42 base plus $3 Texas fee, for $45 before the $25 instant certificate fee — $70 all-in with instant delivery.',
  },
  {
    q: 'Are both courses TDLR-approved?',
    a: 'Yes. Road Ready Safety is approved under CP1234. DefensiveDriving.com is approved under CP284. Both are accepted by Texas courts for ticket dismissal.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

{isEnabled ? (
  <TexasLayout
    title="Road Ready Safety vs DefensiveDriving.com — Texas Defensive Driving (2026)"
    description="Both start at $28. DefensiveDriving.com charges $25 more for your certificate after you finish the course. Here's the full breakdown before you start."
    url="/texas/vs/defensivedriving"
  >
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />

    <article class="bg-white pb-16 lg:pb-24">
      <div class="max-w-[880px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 lg:pt-14">

        <p class="text-sm text-text-body mb-6" style="font-family: 'DM Sans', sans-serif;">
          <a href="/texas" class="text-primary-deep font-medium hover:underline">Texas defensive driving</a>
          <span class="mx-2 text-text-subtle">›</span>
          <a href="/texas/cost" class="text-primary-deep font-medium hover:underline">Compare providers</a>
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-bold text-primary-navy leading-tight tracking-[-0.02em] mb-6" style="font-family: 'Outfit', sans-serif;">
          Road Ready Safety vs DefensiveDriving.com — Texas Defensive Driving (2026)
        </h1>

        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Both courses start at $28. Road Ready Safety includes a free instant certificate download. DefensiveDriving.com charges $25 for instant certificate delivery — revealed after you complete the course. Free delivery is available by standard mail with a 2-plus business day processing window before USPS transit. Both are TDLR-approved.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">If you just got a ticket, here's what you need to know</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>DefensiveDriving.com has been around for a long time and has a large volume of customer reviews. The course works, and most people who complete it get their ticket dismissed.</p>
          <p>The catch is what happens at the end. You start the course at $28. You spend six hours completing it. Then you find out that getting your certificate instantly costs another $25 on top of what you already paid. The free option is standard mail — processed in 2 or more business days, then USPS on top of that. If your court deadline is close, you're looking at $53 all-in.</p>
          <p>Here's everything side by side before you decide.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Side-by-side comparison</h2>

        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0 mb-10 rounded-xl border border-border">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-surface-muted text-left border-b border-border">
                <th class="py-3 px-4 font-semibold text-text" style="font-family: 'DM Sans', sans-serif;"></th>
                <th class="py-3 px-4 font-semibold text-primary" style="font-family: 'DM Sans', sans-serif;">Road Ready Safety</th>
                <th class="py-3 px-4 font-semibold text-text" style="font-family: 'DM Sans', sans-serif;">DefensiveDriving.com (text)</th>
                <th class="py-3 px-4 font-semibold text-text" style="font-family: 'DM Sans', sans-serif;">DefensiveDriving.com (video)</th>
              </tr>
            </thead>
            <tbody style="font-family: 'DM Sans', sans-serif;">
              {[
                { label: 'Base price', rrs: '$28.00', them1: '$28.00', them2: '$45.00' },
                { label: 'Instant certificate', rrs: 'Free', them1: '$25.00 extra', them2: '$25.00 extra' },
                { label: 'True all-in (instant cert)', rrs: '$28.00', them1: '$53.00', them2: '$70.00' },
                { label: 'Free certificate option', rrs: 'Instant download', them1: 'Standard mail, 2+ days processing', them2: 'Standard mail, 2+ days processing' },
                { label: 'TDLR approved', rrs: 'Yes (CP1234)', them1: 'Yes (CP284)', them2: 'Yes (CP284)' },
                { label: 'Refund policy', rrs: '100% refund, no hassle', them1: 'Contact customer service', them2: 'Contact customer service' },
                { label: 'Driving record available', rrs: 'Coming soon', them1: 'Yes ($27.50)', them2: 'Yes ($27.50)' },
                { label: 'Language', rrs: 'English', them1: 'English', them2: 'English' },
              ].map((row, i) => (
                <tr class={`border-b border-border ${i % 2 === 0 ? '' : 'bg-surface-muted/40'}`}>
                  <td class="py-3 px-4 font-semibold text-text">{row.label}</td>
                  <td class="py-3 px-4 text-primary font-medium">{row.rrs}</td>
                  <td class="py-3 px-4 text-text-body">{row.them1}</td>
                  <td class="py-3 px-4 text-text-body">{row.them2}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">What customers say about DefensiveDriving.com</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>DefensiveDriving.com has a large number of reviews across multiple platforms. The course itself generally works. The complaints cluster around one consistent theme — the certificate fee appearing only after the course is finished.</p>
        </div>

        <div class="flex flex-col gap-4 mb-10">
          <div class="bg-green-50 border border-green-200 rounded-xl p-5">
            <p class="text-text-body text-base leading-7 mb-2" style="font-family: 'DM Sans', sans-serif;">"It's good so far and easy to navigate."</p>
            <p class="text-sm text-text-subtle" style="font-family: 'DM Sans', sans-serif;">— Jakyron B., Verified Buyer · Texas · 12 days ago</p>
          </div>
          {[
            { text: "They advertise great benefits then nickel and dime for every little thing. You find out at the end that they'll mail the certificate which takes 7–10 days or you can pay another $10.98 for an instant download.", author: 'JT', date: 'March 2026' },
            { text: "The advertised $25 price is a bait that doesn't include the mandatory fee revealed only after course completion. This junk fee practice is misleading to Texas consumers who have already invested a full day of labor into the program.", author: 'Sean Luka', date: 'March 2026' },
            { text: 'They charge $28 initially. After you spend hours and complete, you need to fork out another $25 for the certificate.', author: 'Kay', date: 'October 2024' },
            { text: 'Never mention anywhere that it costs an extra $25 to download your certificate. Absolute misleading and scammy design.', author: 'Abdullah Omer Manya', date: 'June 2025' },
          ].map(r => (
            <div class="bg-error-bg border border-red-200 rounded-xl p-5">
              <p class="text-text-body text-base leading-7 mb-2" style="font-family: 'DM Sans', sans-serif;">"{r.text}"</p>
              <p class="text-sm text-text-subtle" style="font-family: 'DM Sans', sans-serif;">— {r.author}, {r.date}</p>
            </div>
          ))}
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Where DefensiveDriving.com wins</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Video course option.</strong> They offer a full streamed video course alongside the text course. If you prefer watching over reading, that option exists — at $45 base before the certificate fee.</p>
          <p><strong class="text-text">$250 ticket dismissal guarantee.</strong> If your ticket isn't dismissed after completing the course, they'll pay up to $250 toward it.</p>
          <p><strong class="text-text">A+ BBB rating.</strong> Better Business Bureau gives them their highest rating.</p>
          <p><strong class="text-text">Driving record available.</strong> They offer a driving record as an add-on. At $27.50 it's more expensive than pulling your own Type 3A directly through the DPS portal ($12), but it's available in one place.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Where Road Ready Safety wins</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">The certificate is free and included.</strong> $28 is the total. There's no fee waiting for you at the end of six hours.</p>
          <p><strong class="text-text">No fee revealed after completion.</strong> The most common complaint about DefensiveDriving.com is that the certificate cost only appears after you've finished the course. At Road Ready Safety, the price you see at the start is the price you pay.</p>
          <p><strong class="text-text">100% refund, no hassle.</strong> Changed your mind or found a better option? As long as you haven't completed the course and downloaded your certificate, you can request a full refund directly in the portal with one button. No customer service call, no hold music, no waiting.</p>
          <p><strong class="text-text">Simpler pricing.</strong> One course, one price. No text vs video tier decision, no delivery option menu, no surprise at the end.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Who should choose which</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Choose Road Ready Safety</strong> if you want to pay $28, get your certificate the moment you finish, and know that if anything comes up before you complete the course you can get a full refund instantly from the portal. No surprises going in, no friction going out.</p>
          <p><strong class="text-text">Choose DefensiveDriving.com</strong> if the $250 dismissal guarantee matters to you, you want a video course option, or you want a provider with a long established track record and are prepared to budget $53 all-in for the text course with instant delivery.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Frequently asked questions</h2>
        <div class="space-y-8 mb-12">
          {faqs.map(item => (
            <div>
              <h3 class="text-lg font-semibold text-text mb-2" style="font-family: 'Outfit', sans-serif;">{item.q}</h3>
              <p class="text-text-body text-base leading-7" style="font-family: 'DM Sans', sans-serif;">{item.a}</p>
            </div>
          ))}
        </div>

        <div class="space-y-6 text-text-body text-base leading-7 pt-4 border-t border-border" style="font-family: 'DM Sans', sans-serif;">
          <p class="text-lg font-semibold text-text" style="font-family: 'Outfit', sans-serif;">$28. Free instant certificate. Full refund if you change your mind.</p>
          <div>
            <a
              href={enrollUrl}
              class="inline-flex bg-primary hover:bg-primary-hover text-white h-[56px] px-8 rounded-[16px] text-lg font-semibold items-center justify-center no-underline"
              style="font-family: 'DM Sans', sans-serif; box-shadow: 0px 10px 15px -3px rgba(17,23,34,0.08), 0px 4px 6px -4px rgba(17,23,34,0.05);"
            >
              Start the Course →
            </a>
          </div>
        </div>

      </div>
    </article>
  </TexasLayout>
) : (
  <meta http-equiv="refresh" content="0; url=/" />
)}
