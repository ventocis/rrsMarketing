---
import TexasLayout from '../../../layouts/TexasLayout.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';

const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Road Ready Safety vs SafeMotorist Texas Defensive Driving (2026)',
  dateModified: '2026-05-25',
  datePublished: '2026-05-25',
  author: { '@type': 'Organization', name: 'Road Ready Safety' },
  publisher: { '@type': 'Organization', name: 'Road Ready Safety', url: siteUrl },
});

const faqs = [
  {
    q: "Is SafeMotorist's free certificate actually free?",
    a: "Technically yes — but it's not available to download until 5 days after you complete the course. Instant digital delivery costs $9.95 extra on top of the $25 course fee, bringing the total to $34.95.",
  },
  {
    q: 'Does SafeMotorist have phone support?',
    a: 'Based on customer reports, support is available via email and live chat only.',
  },
  {
    q: 'What happens if you get a security question wrong on SafeMotorist?',
    a: 'SafeMotorist uses timed identity validation questions throughout the course. Four incorrect answers locks your account — you must then contact support to verify your identity and resume.',
  },
  {
    q: "What is Road Ready Safety's refund policy?",
    a: "100% refund as long as you haven't completed the course and downloaded your certificate. Hit the request refund button in the portal — no call or chat required.",
  },
  {
    q: 'Are both courses TDLR-approved?',
    a: 'Yes. Both Road Ready Safety and SafeMotorist are TDLR-approved and accepted by all Texas courts for ticket dismissal.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

{isEnabled ? (
  <TexasLayout
    title="Road Ready Safety vs SafeMotorist Texas Defensive Driving (2026)"
    description="SafeMotorist's free certificate takes 5 days before you can download it. Instant delivery is $9.95 extra. All-in: $34.95 vs $28. Here's the full breakdown."
    url="/texas/vs/safemotorist"
  >
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />

    <article class="bg-white pb-16 lg:pb-24">
      <div class="max-w-[880px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 lg:pt-14">

        <p class="text-sm text-text-body mb-6" style="font-family: 'DM Sans', sans-serif;">
          <a href="/texas" class="text-primary-deep font-medium hover:underline">Texas defensive driving</a>
          <span class="mx-2 text-text-subtle">›</span>
          <a href="/texas/cost" class="text-primary-deep font-medium hover:underline">Compare providers</a>
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-bold text-primary-navy leading-tight tracking-[-0.02em] mb-6" style="font-family: 'Outfit', sans-serif;">
          Road Ready Safety vs SafeMotorist — Texas Defensive Driving (2026)
        </h1>

        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Road Ready Safety costs $28.00 all-in with a free instant certificate download. SafeMotorist's Texas defensive driving course costs $34.95 all-in with instant digital delivery — $25 course fee plus $9.95 for the instant certificate. The free certificate option is not mail. It's a 5-day hold: you finish the course and then wait five days before you're allowed to download your own certificate. Both are TDLR-approved.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">If you just got a ticket, here's what you need to know</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>SafeMotorist positions itself as a straightforward, affordable option. The base price looks competitive at $25. But two things happen that most people don't find out until they're already enrolled.</p>
          <p>First, the certificate. The free option isn't slow mail — it's a 5-day lockout. You complete the course and your certificate sits there, inaccessible, for five full days. If your court deadline is coming up, you're paying $9.95 for the instant download or you're waiting.</p>
          <p>Second, the security questions. SafeMotorist uses identity validation throughout the course — ten personal security questions answered during registration, then randomly prompted during the course with a 45-second timer. Four wrong answers locks your account. You then have to contact customer support to verify your identity and resume. Support is email and chat only — there is no phone number listed.</p>
          <p>Here's the full picture before you decide.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Side-by-side comparison</h2>

        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0 mb-10 rounded-xl border border-border">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-surface-muted text-left border-b border-border">
                <th class="py-3 px-4 font-semibold text-text" style="font-family: 'DM Sans', sans-serif;"></th>
                <th class="py-3 px-4 font-semibold text-primary" style="font-family: 'DM Sans', sans-serif;">Road Ready Safety</th>
                <th class="py-3 px-4 font-semibold text-text" style="font-family: 'DM Sans', sans-serif;">SafeMotorist</th>
              </tr>
            </thead>
            <tbody style="font-family: 'DM Sans', sans-serif;">
              {[
                { label: 'Course fee', rrs: '$25.00', them: '$25.00' },
                { label: 'Instant certificate', rrs: 'Free', them: '$9.95 extra' },
                { label: 'True all-in (instant cert)', rrs: '$28.00', them: '$34.95' },
                { label: 'Free certificate option', rrs: 'Instant download', them: '5-day hold, then download' },
                { label: 'Phone support', rrs: 'Yes', them: 'Email and chat only' },
                { label: 'Security questions / lockout risk', rrs: 'No', them: 'Yes — 4 wrong answers locks account' },
                { label: 'TDLR approved', rrs: 'Yes (CP1234)', them: 'Yes' },
                { label: 'Money-back guarantee', rrs: '100% refund, portal button', them: 'Contact support' },
                { label: 'Language', rrs: 'English', them: 'English' },
              ].map((row, i) => (
                <tr class={`border-b border-border ${i % 2 === 0 ? '' : 'bg-surface-muted/40'}`}>
                  <td class="py-3 px-4 font-semibold text-text">{row.label}</td>
                  <td class="py-3 px-4 text-primary font-medium">{row.rrs}</td>
                  <td class="py-3 px-4 text-text-body">{row.them}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">What customers say about SafeMotorist</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>The reviews available for SafeMotorist follow a consistent theme around pricing transparency and certificate delivery:</p>
        </div>

        <div class="flex flex-col gap-4 mb-6">
          {[
            { text: "A greedy company with predatory practices. They charge you $10 if you don't want to wait a week for a digital certificate that costs them $0. They truly have some of the most obscenely unethical practices I've ever seen.", author: 'Dan Bernstein', date: 'July 2025' },
            { text: "They try to upcharge you at every step. I will be getting a certificate in 14 days by mail — or I can pay $40 extra for express delivery. I have spent significant time trying to contact them via email and chat.", author: 'Jackie Ghosen', date: 'January 2025' },
          ].map(r => (
            <div class="bg-error-bg border border-red-200 rounded-xl p-5">
              <p class="text-text-body text-base leading-7 mb-2" style="font-family: 'DM Sans', sans-serif;">"{r.text}"</p>
              <p class="text-sm text-text-subtle" style="font-family: 'DM Sans', sans-serif;">— {r.author}, {r.date}</p>
            </div>
          ))}
        </div>

        <div class="bg-surface-muted border border-border rounded-xl p-5 mb-10">
          <p class="text-sm text-text-body" style="font-family: 'DM Sans', sans-serif;">The second review also notes that an insurance company had no record of course completion five days after finishing — raising questions about how reliably completions are reported to insurers.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Where SafeMotorist wins</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Established national provider.</strong> SafeMotorist is operated by the American Safety Council and has been offering online driver safety courses for years across multiple states.</p>
          <p><strong class="text-text">Driving record available.</strong> SafeMotorist offers a certified Type 3A driving record delivered within one hour via email — useful if your court requires one alongside your certificate.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Where Road Ready Safety wins</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Free instant certificate — actually instant.</strong> At Road Ready Safety, instant means the moment you finish the course. At SafeMotorist, the free option means waiting 5 days before you can download anything. Getting it immediately costs an extra $9.95.</p>
          <p><strong class="text-text">No security question lockout risk.</strong> SafeMotorist locks your account after four incorrect answers to timed security questions — requiring you to contact support with no phone option available. Road Ready Safety has no equivalent risk.</p>
          <p><strong class="text-text">$6.95 less all-in.</strong> $28 vs $34.95 with instant certificate delivery.</p>
          <p><strong class="text-text">100% refund, one button.</strong> As long as you haven't completed the course and downloaded your certificate, you can request a full refund directly in the portal. No email, no chat queue, no wait.</p>
          <p><strong class="text-text">Phone support.</strong> Road Ready Safety offers phone support. SafeMotorist support is email and chat only.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Who should choose which</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Choose Road Ready Safety</strong> if you want to pay $28, get your certificate the moment you finish, and have access to phone support if something goes wrong.</p>
          <p><strong class="text-text">Choose SafeMotorist</strong> if you need a driving record bundled in one place and are comfortable paying $34.95 all-in for instant delivery, with support handled through email and chat.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Frequently asked questions</h2>
        <div class="space-y-8 mb-12">
          {faqs.map(item => (
            <div>
              <h3 class="text-lg font-semibold text-text mb-2" style="font-family: 'Outfit', sans-serif;">{item.q}</h3>
              <p class="text-text-body text-base leading-7" style="font-family: 'DM Sans', sans-serif;">{item.a}</p>
            </div>
          ))}
        </div>

        <div class="space-y-6 text-text-body text-base leading-7 pt-4 border-t border-border" style="font-family: 'DM Sans', sans-serif;">
          <p class="text-lg font-semibold text-text" style="font-family: 'Outfit', sans-serif;">$28. Free instant certificate.</p>
          <div>
            <a
              href={enrollUrl}
              class="inline-flex bg-primary hover:bg-primary-hover text-white h-[56px] px-8 rounded-[16px] text-lg font-semibold items-center justify-center no-underline"
              style="font-family: 'DM Sans', sans-serif; box-shadow: 0px 10px 15px -3px rgba(17,23,34,0.08), 0px 4px 6px -4px rgba(17,23,34,0.05);"
            >
              Start the Course →
            </a>
          </div>
        </div>

      </div>
    </article>
  </TexasLayout>
) : (
  <meta http-equiv="refresh" content="0; url=/" />
)}
