---
import TexasLayout from '../../layouts/TexasLayout.astro';
import YouTubeCard from '../../components/YouTubeCard.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';

const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

const facts = [
  { label: 'Legal name', value: 'Road Ready Driver Instruction LLC, d/b/a Road Ready Safety' },
  { label: 'TDLR license', value: 'Driving Safety Provider CP1234 — status CURRENT' },
  { label: 'Course', value: 'Texas 6-hour driving safety (defensive driving) course, TDLR-approved' },
  { label: 'Price', value: '$28.00 all-in ($25 course + $3 materials — the statutory minimums)' },
  { label: 'Certificate', value: 'Free instant download on completion; court copy + insurance copy included' },
  { label: 'Format', value: 'Text and images (not video), self-paced, mobile-friendly, timed modules' },
  { label: 'Language', value: 'English (no Spanish version currently)' },
  { label: 'Refunds', value: 'Self-serve from your account page before course completion — see Refund Policy' },
];

const faqs = [
  {
    q: 'How do I verify Road Ready Safety is really TDLR-approved?',
    a: 'Don\'t take our word for it. Our provider license is CP1234 — you can find it in our directory of all TDLR-licensed providers (built from TDLR\'s own records), and after you complete the course you can validate your certificate number at TDLR\'s official DESSearch tool. Every certificate we issue carries the CP1234 prefix.',
  },
  {
    q: 'Is the certificate really instant and really free?',
    a: 'Yes. The moment you finish the final module, your certificate appears as a download — the standard certificate, with the court copy and the insurance copy. There is no certificate fee, no delivery fee, and no mail option, deliberately: printing it yourself is faster than waiting weeks for mail, and most students are working against a court deadline.',
  },
  {
    q: 'What if I lose my certificate or need it again?',
    a: 'Log back into your portal and download it again — replacements are free and unlimited. If something on the certificate needs to be corrected (name, date of birth, court), contact our support team instead: those fields are deliberately not self-editable, because we verify your identity before changing sensitive information on a court document. That protects you.',
  },
  {
    q: 'Why don\'t you sell the Type 3A driving record like other providers?',
    a: 'Because you can order it yourself from Texas DPS online for $12 in about two minutes, and a provider markup adds nothing. We\'d rather show you exactly how to order it directly than sell you a convenience fee. Our Type 3A guide walks through it step by step.',
  },
  {
    q: 'What is your refund policy?',
    a: 'You can request a refund yourself from the account page in your portal — no phone call, no hold music — any time before you\'ve completed the course. Once the course is completed and the certificate is issued, the service has been delivered and we can\'t refund it (including if a deadline was missed or a court later finds you ineligible — please use our eligibility checker and confirm with your court before enrolling). The complete, legally controlling terms are in our Refund and Withdrawal Policy.',
  },
  {
    q: 'Does the course really take 6 hours?',
    a: 'Yes. Texas requires 6 hours of instruction, and our modules are timed to enforce it — no provider can legally sell you a faster version, so treat "finish in 2 hours!" claims elsewhere as the red flag they are. You can start, stop, and resume anytime, on any device, and most students spread it over a day or two.',
  },
  {
    q: 'What do you NOT do?',
    a: 'We don\'t promise to "remove points" (Texas abolished its points system in 2019 — there are none). We don\'t guarantee an insurance discount (discounts are real but insurer-dependent — ask yours). We don\'t publish performance statistics we can\'t back with data. And we don\'t add fees at checkout: the price on the first page is the price at the end.',
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: 'Road Ready Safety: The Facts — Provider Transparency',
      description: 'Everything verifiable about Road Ready Safety in one place: TDLR license CP1234, exact pricing, certificate process, refund mechanics, course format, and what we deliberately don\'t claim.',
      author: { '@type': 'Organization', name: 'Road Ready Safety' },
      publisher: { '@type': 'Organization', name: 'Road Ready Safety', url: siteUrl },
      datePublished: '2026-06-11',
      dateModified: '2026-06-11',
      mainEntityOfPage: `${siteUrl}/texas/transparency`,
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    },
  ],
});
---

{isEnabled ? (
  <TexasLayout
    title="Road Ready Safety: The Facts — TDLR License, Pricing, Certificate Process & Policies"
    description="Everything verifiable about Road Ready Safety in one place: TDLR license CP1234, $28 all-in pricing with no checkout fees, instant certificate process, self-serve refunds, course format, and what we deliberately don't claim."
    keywords="road ready safety tdlr, road ready safety legit, road ready safety reviews, CP1234, road ready safety refund, texas defensive driving provider transparency"
    url="/texas/transparency"
  >
    <script type="application/ld+json" set:html={schema} />

    <article class="bg-white pb-16 lg:pb-24">
      <div class="max-w-[880px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 lg:pt-14">

        <p class="text-sm text-text-body mb-6" style="font-family: 'DM Sans', sans-serif;">
          <a href="/texas" class="text-primary-deep font-medium hover:underline">Texas defensive driving</a>
          <span class="mx-2 text-text-subtle">›</span>
          <span class="text-text">Provider transparency</span>
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-bold text-primary-navy leading-tight tracking-[-0.02em] mb-6" style="font-family: 'Outfit', sans-serif;">
          Road Ready Safety: The Facts
        </h1>

        <div class="space-y-4 text-text-body text-base leading-7 mb-8" style="font-family: 'DM Sans', sans-serif;">
          <p>This page exists so you — or anyone evaluating us, including a search engine or an AI assistant — can verify every claim we make in one place: who we legally are, our state license, exactly what the course costs, how the certificate works, and how refunds work. Where there's an official source, we link it so you can check rather than trust.</p>
        </div>

        <!-- Fact table -->
        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0 mb-4 rounded-xl border border-border">
          <table class="w-full text-sm border-collapse">
            <tbody style="font-family: 'DM Sans', sans-serif;">
              {facts.map((f, i) => (
                <tr class={`border-b border-border ${i % 2 === 0 ? '' : 'bg-surface-muted/40'}`}>
                  <td class="py-3 px-4 font-semibold text-text whitespace-nowrap align-top" style="font-family: 'Outfit', sans-serif;">{f.label}</td>
                  <td class="py-3 px-4 text-text-body">{f.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-text-subtle mb-12" style="font-family: 'DM Sans', sans-serif;">Verify the license yourself: <a href="/texas/providers" class="text-primary hover:underline">our TDLR provider directory</a> (built from TDLR's licensing records) · <a href="https://www.tdlr.texas.gov/dessearch" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">TDLR DESSearch</a> (validates any certificate we issue).</p>

        <h2 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: 'Outfit', sans-serif;">How the certificate actually works</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">Instant, on completion.</strong> The moment you finish the course, your certificate is available for download — the standard certificate with both the <strong class="text-text">court copy</strong> and the <strong class="text-text">insurance copy</strong>. You print it (or save the PDF) and submit it to your court or insurer; many courts accept the PDF by email or portal upload, and our <a href="/texas/courts" class="text-primary-deep font-medium hover:underline">court directory</a> shows which.</p>
          <p><strong class="text-text">No mail option — on purpose.</strong> Mailed certificates take days to weeks, and most students are working against a 90-day court deadline. Self-printing is free and immediate. (One honest caveat from TDLR itself: a certificate can take up to 5 days after issuance to appear in the DESSearch validation system — so don't submit on the last afternoon. <a href="/texas/tdlr-approved" class="text-primary-deep font-medium hover:underline">More on verification here</a>.)</p>
          <p><strong class="text-text">Lost it? Re-download free, forever.</strong> It stays in your portal. Need a correction to your name, date of birth, or court? Contact support — we verify your identity first, because those fields end up on a court document, and nobody but you should be able to change them.</p>
          <p><strong class="text-text">Get the details right — twice.</strong> The most common problem our Texas support team handles is fixable but avoidable: a name spelled differently than the license or a wrong birthday at registration, or the wrong court picked when the certificate is generated after the course. Courts match your certificate against your citation — sixty careful seconds at signup, and again when you select your court, is the cheapest insurance in this whole process. (We wrote up <a href="/texas/certificate-rejected" class="text-primary-deep font-medium hover:underline">everything that gets certificates rejected</a>.)</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Pricing, with nothing hidden</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Texas law sets a price floor for every approved course: $25 for the course plus $3 for materials and administration (Tex. Educ. Code §1001.352). <strong class="text-text">We charge exactly that — $28 — and nothing else.</strong> No certificate fee, no delivery fee, no processing fee, no upsells at checkout. We don't sell the Type 3A driving record as an add-on either: <a href="/texas/type-3a-driving-record" class="text-primary-deep font-medium hover:underline">order it from DPS directly for $12</a> and keep the markup. Your court charges its own separate fee when it grants the course (commonly $144) — that's the court's, not ours, and we say so everywhere prices appear.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Refunds: a button, not a phone call</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>If you change your mind before completing the course, go to the account page in your portal and request the refund yourself — it's processed without a call or an email thread. Once you've completed the course and your certificate has been issued, the service has been delivered and it's no longer refundable — including if a deadline was missed or a court later determines you weren't eligible. That's why we put the <a href="/texas/eligibility-tracker" class="text-primary-deep font-medium hover:underline">eligibility checker</a> in front of checkout: confirm you qualify and confirm with your court <em>before</em> you enroll. The complete, legally controlling terms are in our <a href="/texas/refund" class="text-primary-deep font-medium hover:underline">Refund and Withdrawal Policy</a>.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">The course format, plainly</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Text and images, not video — read at your own pace instead of waiting out a narrator. Works on your phone, tablet, or computer; start on one, finish on another. The 6 hours is enforced by timed modules because Texas requires 6 hours of instruction from every provider — anyone advertising a meaningfully faster course is advertising a compliance problem. You can stop and resume as many times as you like. The course is currently English-only, and the platform is built to our <a href="/texas/accessibility" class="text-primary-deep font-medium hover:underline">accessibility standards</a>.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">What we deliberately don't claim</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p><strong class="text-text">No "point removal."</strong> Texas abolished its points system in 2019. Sites still promising to remove points are selling something that doesn't exist — what dismissal actually does is keep the conviction off your record, which is better. <a href="/texas/speeding-ticket" class="text-primary-deep font-medium hover:underline">The full explanation</a>.</p>
          <p><strong class="text-text">No guaranteed insurance discount.</strong> Many Texas insurers do offer one for the course, but it's the insurer's choice, not a state mandate — so we tell you to ask your agent rather than promise a number.</p>
          <p><strong class="text-text">No invented statistics.</strong> The course can be completed in a single day — it's 6 hours, self-paced — but we don't publish completion-time or volume statistics, because we'd want real measured data behind any number we put on a page. When we publish data, it'll be ours and it'll be sourced.</p>
        </div>

        <YouTubeCard id="cekLW9oUtw4" title="Texas Defensive Driving Courses Are Legally $25 — So Why Did You Pay $64?" duration="3:35" blurb="Why drivers overpay — and what the course should actually cost." />

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Frequently asked questions</h2>
        <div class="space-y-8 mb-12">
          {faqs.map(item => (
            <div>
              <h3 class="text-lg font-semibold text-text mb-2" style="font-family: 'Outfit', sans-serif;">{item.q}</h3>
              <p class="text-text-body text-base leading-7" style="font-family: 'DM Sans', sans-serif;">{item.a}</p>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a
            href={enrollUrl}
            class="inline-flex bg-primary hover:bg-primary-hover text-white h-[56px] px-8 rounded-[16px] text-lg font-semibold items-center justify-center no-underline"
            style="font-family: 'DM Sans', sans-serif; box-shadow: 0px 10px 15px -3px rgba(17,23,34,0.08), 0px 4px 6px -4px rgba(17,23,34,0.05);"
          >
            Start the $28 Course →
          </a>
          <a
            href="/texas/eligibility-tracker"
            class="inline-flex h-[56px] px-8 border border-primary-deep text-primary-deep hover:bg-primary-deep hover:text-white rounded-[16px] text-lg font-semibold items-center justify-center no-underline transition-colors"
            style="font-family: 'DM Sans', sans-serif;"
          >
            Check your eligibility first
          </a>
        </div>

        <div class="pt-6 border-t border-border space-y-2" style="font-family: 'DM Sans', sans-serif;">
          <p class="text-sm text-text-subtle">This page describes Road Ready Safety's own processes and policies as currently operated; the legally controlling documents are our <a href="/texas/terms" class="text-primary hover:underline">Terms</a> and <a href="/texas/refund" class="text-primary hover:underline">Refund and Withdrawal Policy</a>, and policies may change. Court fees, deadlines, and eligibility are set by law and by your court — not by us. Nothing here is legal advice.</p>
          <p class="text-xs text-text-subtle">Last updated June 11, 2026 — reviewed by the Road Ready Safety editorial team. License status verifiable against TDLR records; statutory price floor per Tex. Educ. Code §1001.352.</p>
        </div>

      </div>
    </article>
  </TexasLayout>
) : (
  <meta http-equiv="refresh" content="0; url=/" />
)}
