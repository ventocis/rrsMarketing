# Copy to .env.local and set values as needed.
# Used at build time by Vite (only VITE_* vars are exposed to client).
# Pipeline: npm run build:qa loads .env.qa (Texas on, QA URLs); npm run build:prod loads .env.production (Texas off, prod URLs).
# For local overrides, use .env.local; build:qa / build:prod use --mode qa / production and load the env file for that mode.

# Marketing site's own URL — used in SEO metadata and canonical links
VITE_SITE_URL=https://roadreadysafety.com

# Portal application URL — used for enrollment links on non-partner courses
VITE_PORTAL_URL=https://app.roadreadysafety.com

# Analytics — leave blank for QA/dev, set for prod
VITE_GA4_ID=
VITE_GOOGLE_ADS_ID=
VITE_ENABLE_ANALYTICS=false

# When true, components use course.qa_link instead of course.affiliate_link for enrollment CTAs
VITE_IS_QA=false

# Texas routes: set to "true" to enable /texas and related routes (e.g. QA build).
# Leave unset or "false" for prod (no /texas).
# VITE_TEXAS_ROUTES_ENABLED=true

# Texas enrollment URL: when set, all Texas "Start Course" / "Enroll" CTAs use this URL.
# Leave unset for prod (CTAs go to /courses/tx-defensive → affiliate link).
# QA example:
# VITE_TEXAS_ENROLLMENT_URL=https://app.qa.roadreadysafety.com/public/checkout?sku=tx-bdi
#
# Main site Contact Us URL — where /support and all "Contact Us" / "Help Center" links go (main site and Texas).
# QA: app.qa.roadreadysafety.com/contact — Prod: app.roadreadysafety.com/contact
# VITE_CONTACT_US_URL=https://app.roadreadysafety.com/contact
#
# Portal login URL — when set, header "Log In" goes here (returnUrl= current path is appended). Leave unset for prod (button does nothing).
# VITE_LOGIN_URL=https://app.qa.roadreadysafety.com/public/login
#
# Local preview ports (convention):
# - Prod build: npm run build:prod && npm run preview  → http://localhost:4173
# - QA build:  npm run preview:qa                      → http://localhost:4174
