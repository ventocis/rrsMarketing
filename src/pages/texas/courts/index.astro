---
import TexasLayout from '../../../layouts/TexasLayout.astro';
import TexasCourtsFilter from '../../../components/TexasCourtsFilter';
import courtsData from '../../../data/texas-courts.json';

const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
---

{!isEnabled && (
  <meta http-equiv="refresh" content="0;url=/" />
)}

{isEnabled && (
  <TexasLayout
    title="Texas Court Directory — Find Your Court | Road Ready Safety"
    description="Find your Texas court and get step-by-step instructions for completing your Driver Safety Course. Search by court name, county, or judge name."
    keywords="Texas court directory, find Texas court, traffic court Texas, driver safety course court, defensive driving court"
    url="/texas/courts"
  >
    <section class="pt-8 pb-[112px] px-4 sm:px-6 lg:px-8 bg-surface-muted">
      <div class="max-w-7xl mx-auto">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-text-body mb-8">
          <a href="/texas" class="hover:text-text transition-colors no-underline">Texas</a>
          <span>›</span>
          <span class="text-text font-medium">Courts</span>
        </nav>

        <!-- Page Header -->
        <div class="mb-8">
          <h1 class="text-[36px] font-bold text-text leading-[40px] tracking-[-0.9px] mb-4">
            Texas Court Directory
          </h1>
          <p class="text-base text-text-body leading-6 mb-8">
            Find your court and get step-by-step instructions for completing your Driver Safety Course. Search by court name, county, or judge name.
          </p>
        </div>

        <!-- Courts Filter & Listing -->
        <TexasCourtsFilter courts={courtsData.courts} client:load />

      </div>
    </section>
  </TexasLayout>
)}
