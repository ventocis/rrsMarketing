---
import DocLayout from '../layouts/DocLayout.astro';
import { marked } from 'marked';
import { readFileSync } from 'fs';
import { join } from 'path';

const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const raw = readFileSync(join(process.cwd(), 'src/content/docs/terms.md'), 'utf-8');
const html = marked(raw.replace('{{today}}', today));
---

<DocLayout
  title="Terms of Service"
  description="Road Ready Safety's terms of service. Read our terms and conditions before enrolling in a course."
  url="/terms"
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Terms of Service' }]}
>
  <Fragment set:html={html} />
</DocLayout>
