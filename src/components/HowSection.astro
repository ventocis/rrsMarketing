---
import homeData from '../copy/home.json';
const { heading, steps } = homeData.how;
---

<section id="how-it-works" class="bg-white py-16 lg:py-24 border-b border-[#e5e5e5]">
  <div class="max-w-[1152px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 items-center mb-12">
      <div class="bg-[#e5f6fe] inline-flex items-center px-4 py-2 rounded-full">
        <span class="text-sm font-semibold text-[#0351b4] leading-5">Simple Steps</span>
      </div>
      <h2 class="text-[28px] lg:text-[36px] font-bold text-center text-[#1e2832] tracking-[-0.02em] lg:tracking-[-0.9px] leading-[150%] lg:leading-[40px]">
        {heading}
      </h2>
      <p class="text-base text-center text-[#616d7b] leading-6 max-w-[672px]">
        Learn at your own pace on any device. Your progress is saved automatically so you can pick up right where you left off.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12 lg:gap-16">
      <div class="max-w-[65ch]">
        <ol class="space-y-8">
          {steps.map((step) => (
            <li class="flex items-start">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0667D1] text-white flex items-center justify-center font-bold text-lg mr-4" aria-hidden="true">{step.n}</span>
              <div>
                <h3 class="text-xl font-medium text-[#262626] mb-1 tracking-[-0.02em]" style="line-height: 30px;">{step.title}</h3>
                <p class="text-base leading-[22px] text-[#616d7b] mb-1">{step.body}</p>
                {step.link && (
                  <a href={step.link.href} class="text-[#0667D1] hover:text-[#0556b3] text-sm underline underline-offset-2 focus:outline-none focus:ring-2 focus:ring-[#0667D1] focus:ring-offset-2 rounded">
                    {step.link.label}
                  </a>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>

      <div class="hidden lg:block">
        <img
          src="/assets/illustrations/add-tasks.svg"
          alt="How it works — step-by-step process illustration"
          class="h-72 md:h-96 lg:h-[32rem] xl:h-[36rem] mx-auto lg:ml-auto"
          width="480"
          height="512"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
