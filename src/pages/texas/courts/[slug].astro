              <h3 class="text-lg font-semibold text-text leading-6 pr-2">Texas Defensive Driving Course 6hr</h3>
              <div class="bg-info px-2 py-0.5 rounded-2xl flex-shrink-0">
                <span class="text-xs font-semibold text-primary">Great Value</span>
              </div>
            </div>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-[32px] font-bold text-text leading-9">$25</span>
              <span class="text-xs text-text-body">.00</span>
              <span class="text-lg font-medium text-text-body line-through ml-2">$35.00</span>
            </div>
            <p class="text-xs text-text-body mb-3">+ $3.00 state processing fee</p>
            <div class="flex gap-1 items-center mb-4">
              {[...Array(5)].map(() => (
                <img src="/assets/icons/texas/star-pricing.svg" alt="" class="w-3.5 h-3.5" />
              ))}
              <span class="text-xs font-medium text-text ml-1">4.9 out of 5</span>
            </div>
            <a
              href={enrollUrl}
              class="w-full h-11 bg-primary hover:bg-primary-hover text-white rounded-2xl text-sm font-semibold flex items-center justify-center gap-2 no-underline transition-colors mb-3 shadow-sm"
            >
              Enroll Now
              <img src="/assets/icons/texas/arrow-enroll.svg" alt="" class="w-3 h-3" />
            </a>
            <div class="flex flex-col gap-2">
              {[
                "Secure checkout",
                "TDLR-approved provider",
                "100% money-back guarantee",
                "Instant Certificate Download",
                "Compatible with any device",
              ].map(item => (
                <div class="flex gap-2 items-center">
                  <div class="bg-info rounded-full w-5 h-5 flex items-center justify-center flex-shrink-0">
                    <img src="/assets/icons/texas/checkmark-feature.svg" alt="" class="w-3 h-3" />
                  </div>
                  <span class="text-xs text-text-body">{item}</span>
                </div>
              ))}
            </div>
          </div>

        </div>

      </div><!-- /two col -->
    </div>
  </section>

</TexasLayout>
