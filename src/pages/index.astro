---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroFinder from '../components/HeroFinder';
import UspSection from '../components/UspSection.astro';
import HowSection from '../components/HowSection.astro';
import TrustSection from '../components/TrustSection.astro';
import FaqSection from '../components/FaqSection.astro';

const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';
---

<Layout
  title="Online Defensive Driving Course | Road Ready Safety"
  description="State-approved defensive driving courses accepted by courts nationwide. Affordable, convenient, and built for busy people."
  keywords="traffic school, defensive driving, online course, traffic ticket, driver improvement, state approved"
  image="/assets/rrs (1200 x 630 px).png"
  url="/"
>
  <!-- JSON-LD: Website -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Road Ready Safety",
      "url": "https://roadreadysafety.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://roadreadysafety.com/courses?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  </script>

  <Header />

  <main>
    <!-- Hero + Course Finder -->
    <section
      class="relative border-b border-border py-16 lg:py-24 overflow-hidden"
      id="find-course"
      style="font-family: 'Inter', sans-serif;"
    >
      <div class="absolute inset-0 bg-gradient-to-b from-info opacity-50 to-white pointer-events-none"></div>
      <div class="relative max-w-[1152px] mx-auto px-4 sm:px-6 lg:px-8 z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12 lg:gap-16">

          <!-- Left: heading + finder form -->
          <div class="max-w-[65ch] text-center lg:text-left">
            <h1 class="mb-6 text-[40px] leading-[52px] font-extrabold text-text tracking-[-0.02em]">
              Dismiss your ticket. Lower your rates. Get it done fast.
            </h1>
            <p class="text-base leading-[22px] text-text-body mb-12">
              State-approved, mobile-friendly, and built to save your progress. Learn at your pace, pass the quizzes, and get your certificate without the hassle.
            </p>
            <div class="max-w-xl mx-auto lg:mx-0 mt-12">
              <!-- HeroFinder is a React island — only this form hydrates client-side -->
              <HeroFinder variant="hero" client:load />
            </div>
          </div>

          <!-- Right: illustration -->
          <div class="hidden lg:block">
            <img
              src="/assets/illustrations/product-explainer.svg"
              alt="Modern traffic course interface showing mobile and desktop compatibility"
              class="h-64 md:h-80 lg:h-96 xl:h-[28rem] mx-auto lg:ml-auto"
              width="448"
              height="448"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <UspSection />
    <HowSection />
    <TrustSection />
    <FaqSection />

    <!-- CTA section -->
    <section class="bg-white py-16 lg:py-24 border-b border-border">
      <div class="max-w-[1152px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative bg-primary-deep rounded-[24px] p-8 lg:p-16 overflow-hidden">
          <!-- Background blur effects -->
          <div class="absolute inset-0 opacity-10 pointer-events-none select-none z-0" aria-hidden="true">
            <div class="absolute bg-[#46a2f2] blur-[32px] right-[-192px] rounded-full w-[384px] h-[384px] top-[-192px]"></div>
            <div class="absolute bg-[#46a2f2] blur-[32px] bottom-[-128px] left-[-128px] rounded-full w-[256px] h-[256px]"></div>
          </div>

          <div class="relative z-10 flex flex-col gap-6 items-center max-w-[768px] mx-auto">
            <h2 class="text-[28px] lg:text-[36px] font-bold text-center text-white tracking-[-0.02em] lg:tracking-[-0.9px] leading-[150%] lg:leading-[40px]">
              Ready to Dismiss Your Ticket?
            </h2>
            <p class="text-base text-center text-[#b9e2fe] leading-6 max-w-[672px]">
              Join thousands of drivers who have successfully completed their defensive driving course with Road Ready Safety. Start today and get your certificate instantly.
            </p>
            <div class="w-full max-w-xl mt-4">
              <HeroFinder variant="cta" client:visible />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
