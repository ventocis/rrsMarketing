# Copy to .env.local and set values as needed.
# All vars are baked in at build time (SSG — no server runtime). VITE_* vars are exposed to client.
# Pipeline: npm run build:qa loads .env.qa (Texas on, QA URLs); npm run build:prod loads .env.production.
# For local overrides, use .env.local.

# Marketing site's own URL — used in SEO metadata, canonical links, and sitemap
VITE_SITE_URL=https://roadreadysafety.com

# Portal application URL — used for enrollment links on non-partner courses
VITE_PORTAL_URL=https://app.roadreadysafety.com

# Analytics — leave blank for QA/dev, set for prod
VITE_GA4_ID=
VITE_GOOGLE_ADS_ID=
VITE_ENABLE_ANALYTICS=false

# When true, components use course.qa_link instead of course.affiliate_link for enrollment CTAs
VITE_IS_QA=false

# Texas routes: set to "true" to enable /texas and related routes (e.g. QA build).
# Leave unset or "false" for prod (no /texas).
# VITE_TEXAS_ROUTES_ENABLED=true

# Texas enrollment URL: when set, all Texas "Start Course" / "Enroll" CTAs use this URL.
# VITE_TEXAS_ENROLLMENT_URL=https://app.qa.roadreadysafety.com/public/checkout?sku=tx-bdi

# Contact Us URL — where /support and all "Help Center" links redirect.
# VITE_CONTACT_US_URL=https://app.roadreadysafety.com/contact

# Portal login URL — when set, header "Log In" goes here. Leave unset to hide button.
# VITE_LOGIN_URL=https://app.qa.roadreadysafety.com/public/login
