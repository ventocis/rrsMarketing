---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  url="/404"
  noindex={true}
>
  <Header />

  <main class="bg-surface-muted min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-md w-full text-center">

      <!-- Error code -->
      <p class="text-8xl font-extrabold text-border leading-none mb-4" style="font-family: 'Outfit', sans-serif;">
        404
      </p>

      <!-- Heading -->
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-3 leading-tight" style="font-family: 'Outfit', sans-serif;">
        Page not found
      </h1>

      <!-- Subtext -->
      <p class="text-base text-text-body leading-relaxed mb-8" style="font-family: 'DM Sans', sans-serif;">
        The page you're looking for doesn't exist or may have moved. Let's get you back on the road.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center h-11 px-6 bg-primary hover:bg-primary-hover text-white text-sm font-semibold rounded-xl transition-colors"
          style="font-family: 'DM Sans', sans-serif;"
        >
          Go to Homepage
        </a>
        <a
          href="/courses"
          class="inline-flex items-center justify-center h-11 px-6 border border-border bg-white hover:bg-surface-muted text-text text-sm font-semibold rounded-xl transition-colors"
          style="font-family: 'DM Sans', sans-serif;"
        >
          Browse Courses
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
