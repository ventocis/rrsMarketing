---
import TexasLayout from '../../layouts/TexasLayout.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';
const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

const faqs = [
  {
    "q": "How much does it cost to dismiss a ticket in El Paso?",
    "a": "The court cost is typically up to about $144 ($169 in a school zone), set by each court — some El Paso-area courts charge less. The TDLR-approved course is separate; ours is $28. Check your court's page for the exact amount."
  },
  {
    "q": "Can I take the El Paso defensive driving course online?",
    "a": "Yes. Once the court approves your request, a TDLR-approved 6-hour course can be completed fully online. Every El Paso-area court accepts a state-approved online course."
  },
  {
    "q": "My ticket is from Socorro / Horizon City / San Elizario, not El Paso. Does that change things?",
    "a": "The legal steps are the same, but you deal with that city's court — each with its own fee, request method, and deadlines. Open its page in the table above."
  },
  {
    "q": "How long do I have to finish?",
    "a": "Generally 90 days after the court approves the request. Request the course by your appearance date first, and don't pay the ticket — paying is a guilty plea and a conviction."
  },
  {
    "q": "Does a dismissal keep it off my insurance?",
    "a": "Yes. A driving safety course dismissal keeps the charge off your driving record under Texas law, so it can't raise your insurance — unlike paying, which is a conviction."
  }
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: "How to Dismiss a Traffic Ticket in El Paso with Defensive Driving", description: "Dismiss an El Paso-area traffic ticket: request a driving safety course by your appearance date, finish a 6-hour course in 90 days, submit your certificate. 'El Paso' spans several El Paso County courts — here's how each differs.",
  author: { '@type': 'Organization', name: 'Road Ready Safety' },
  publisher: { '@type': 'Organization', name: 'Road Ready Safety', url: siteUrl },
  datePublished: '2026-06-13', dateModified: '2026-06-13',
  mainEntityOfPage: `${siteUrl}/texas/el-paso`,
});
const faqSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
});
---

{isEnabled ? (
  <TexasLayout title="How to Dismiss a Traffic Ticket in El Paso with Defensive Driving (2026)" description="Dismiss an El Paso-area traffic ticket: request a driving safety course by your appearance date, finish a 6-hour course in 90 days, submit your certificate. 'El Paso' spans several El Paso County courts — here's how each differs." keywords="dismiss ticket el paso, el paso defensive driving, el paso traffic ticket dismissal, driving safety course el paso, socorro horizon city san elizario defensive driving, el paso county speeding ticket" url="/texas/el-paso">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />

    <article class="bg-white pb-16 lg:pb-24">
      <div class="max-w-[880px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 lg:pt-14">

        <p class="text-sm text-text-body mb-6" style="font-family: 'DM Sans', sans-serif;">
          <a href="/texas" class="text-primary-deep font-medium hover:underline">Texas defensive driving</a>
          <span class="mx-2 text-text-subtle">›</span>
          <span class="text-text">El Paso</span>
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-bold text-primary-navy leading-tight tracking-[-0.02em] mb-6" style="font-family: 'Outfit', sans-serif;">
          How to Dismiss a Traffic Ticket in El Paso with Defensive Driving
        </h1>

        <div class="space-y-4 text-text-body text-base leading-7 mb-8" style="font-family: 'DM Sans', sans-serif;">
          <p><strong>Short answer:</strong> to dismiss an El Paso-area traffic ticket, request a driving safety course from the court <strong>on or before your appearance date</strong>, complete a TDLR-approved 6-hour course within 90 days, and submit your certificate plus a certified DPS driving record. The charge is then dismissed and kept off your record.</p>
          <p><strong>The catch:</strong> a ticket "in El Paso" might actually be at one of the surrounding El Paso County city courts — and each sets its own fee and process. Here's what's the same everywhere and how the local courts differ.</p>
        </div>

        <div class="bg-surface-muted border border-border rounded-xl p-5 mb-10">
          <p class="text-sm text-text-body" style="font-family: 'DM Sans', sans-serif;">This page is general information, not legal advice. Each court sets its own fees, deadlines, and procedures — confirm with the specific court on your citation. Road Ready Safety is a TDLR-licensed course provider, not a court.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">"El Paso" isn't one court</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Read the <strong>court name on your citation</strong>. The City of El Paso runs its own municipal court; the surrounding El Paso County cities each run theirs.</p>
          <p>Besides the <strong>City of El Paso Municipal Court</strong>, El Paso County includes <strong>Socorro, Horizon City, San Elizario, Clint, and Anthony</strong> (the Mission Valley, far-east, and New Mexico-line communities). The city where you were stopped is your court.</p>
          <p>Tickets written by a <strong>DPS trooper or sheriff's deputy</strong> on I-10 or county roads outside the city limits go to an <strong>El Paso County Justice of the Peace</strong> court. Same general process, different office.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">What's the same at every El Paso-area court</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>Texas law sets the core rules, so the basic path to a dismissal is the same no matter which El Paso-area court has your ticket:</p>
        </div>
        <div class="bg-surface-muted border border-border rounded-xl p-5 mb-10">
          <ul class="flex flex-col gap-2 list-none m-0 p-0 text-sm text-text-body">
            <li>• <strong>Request the course by your appearance/answer date</strong> — the date on your citation. Don't pay first: paying is a guilty plea and a conviction.</li>
            <li>• You need a <strong>valid Texas driver license and proof of insurance</strong>, and you plead guilty or no contest.</li>
            <li>• You can use it <strong>once every 12 months</strong>. It's <strong>not</strong> available for speeding 25+ mph over the limit (or 95+ mph), CDL holders, passing a school bus, or work-zone violations with workers present.</li>
            <li>• Court costs run <strong>up to about $144</strong> ($169 in a school zone) and are set by each court — some charge less.</li>
            <li>• After approval you have <strong>90 days</strong> to finish a TDLR-approved 6-hour course and submit the certificate plus a certified DPS <a href="/texas/type-3a-driving-record" class="text-primary-deep font-medium hover:underline">Type 3A driving record</a>.</li>
            <li>• Complete it and the charge is <strong>dismissed and kept off your record</strong> under Texas law (Code of Criminal Procedure ch. 45A) — it can't be used against you or raise your insurance.</li>
          </ul>
        </div>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>Want the full walkthrough? See <a href="/texas/speeding-ticket" class="text-primary-deep font-medium hover:underline">how Texas ticket dismissal works</a>, or <a href="/texas/eligibility-tracker" class="text-primary-deep font-medium hover:underline">check your eligibility</a>.</p>
        </div>
        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">How El Paso-area courts differ</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-4" style="font-family: 'DM Sans', sans-serif;">
          <p>The fee, how you request the course, the exact deadline, and small local rules vary court to court. Here are the 6 El Paso-area courts we've researched — tap any one for its full instructions, fees, and contacts.</p>
        </div>
        <div class="overflow-x-auto my-2">
          <table class="w-full text-sm border-collapse" style="font-family: 'DM Sans', sans-serif;">
            <thead><tr class="border-b-2 border-border text-left"><th class="py-2 pr-4 font-semibold text-text">El Paso-area court</th><th class="py-2 font-semibold text-text">What to know (tap to open the court page)</th></tr></thead>
            <tbody>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-el-paso" class="text-primary-deep font-semibold hover:underline">El Paso Municipal Court</a></td>
                <td class="py-3 text-text-body">You'll need a certified Type 3A driving record from Texas DPS — most drivers do not have this ready.</td>
              </tr>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-anthony" class="text-primary-deep font-semibold hover:underline">Anthony Municipal Court</a></td>
                <td class="py-3 text-text-body">Anthony Municipal Court (El Paso County, TX — on the TX–NM line at I-10) hasn't posted its DSC fee — call (915) 886-3272 or email AMC@townofanthonytx.org by your appearance date to request dismissal.</td>
              </tr>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-clint" class="text-primary-deep font-semibold hover:underline">Clint Municipal Court</a></td>
                <td class="py-3 text-text-body">Got a ticket in Clint (El Paso County, SE metro)? The Clint Municipal Court hasn't posted its DSC fee — call (915) 851-3146 by your appearance date to confirm the amount and request the driving safety course option. Complete a TDLR-approved course and submit your certificate to get the ticket dismissed.</td>
              </tr>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-horizon-city" class="text-primary-deep font-semibold hover:underline">Horizon City Municipal Court</a></td>
                <td class="py-3 text-text-body">Horizon City Municipal Court (El Paso County, I-10 east) handles traffic ticket dismissals via Driver Safety Course — the court hasn't posted its DSC fee online, so call (915) 852-1048 before your appearance date. Take the course online for</td>
              </tr>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-san-elizario" class="text-primary-deep font-semibold hover:underline">San Elizario Municipal Court</a></td>
                <td class="py-3 text-text-body">San Elizario Municipal Court (El Paso County) hasn't posted its DSC fee online — call (915) 302-2050 before your appearance date to confirm. Take a</td>
              </tr>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/el-paso-municipal-socorro" class="text-primary-deep font-semibold hover:underline">Socorro Municipal Court</a></td>
                <td class="py-3 text-text-body">Socorro accepts DSC requests by email — $144 court fee, and both completion documents must be submitted together.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10 mt-4" style="font-family: 'DM Sans', sans-serif;">
          <p>Don't see your court? Search every Texas court in our <a href="/texas/courts" class="text-primary-deep font-medium hover:underline">court directory</a>.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Frequently asked questions</h2>
        <div class="space-y-8 mb-12">
          {faqs.map(item => (
            <div>
              <h3 class="text-lg font-semibold text-text mb-2" style="font-family: 'Outfit', sans-serif;">{item.q}</h3>
              <p class="text-text-body text-base leading-7" style="font-family: 'DM Sans', sans-serif;" set:html={item.a} />
            </div>
          ))}
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">Take the El Paso course that every court accepts</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-8" style="font-family: 'DM Sans', sans-serif;">
          <p>Once your court approves the request, our TDLR-approved course is accepted at every El Paso-area court — $28, fully online, with the certificate the moment you finish.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a href={enrollUrl} class="inline-flex bg-primary hover:bg-primary-hover text-white h-[56px] px-8 rounded-[16px] text-lg font-semibold items-center justify-center no-underline" style="font-family: 'DM Sans', sans-serif; box-shadow: 0px 10px 15px -3px rgba(17,23,34,0.08), 0px 4px 6px -4px rgba(17,23,34,0.05);">
            Start the $28 Course →
          </a>
          <a href="/texas/courts" class="inline-flex h-[56px] px-8 border border-primary-deep text-primary-deep hover:bg-primary-deep hover:text-white rounded-[16px] text-lg font-semibold items-center justify-center no-underline transition-colors" style="font-family: 'DM Sans', sans-serif;">
            Browse all Texas courts
          </a>
        </div>

        <div class="pt-6 border-t border-border space-y-2" style="font-family: 'DM Sans', sans-serif;">
          <p class="text-sm text-text-subtle">Road Ready Safety is a TDLR-licensed Texas driving safety provider (CP#1234). This page is informational and not legal advice; confirm requirements with the court on your citation.</p>
          <p class="text-xs text-text-subtle">Last updated June 13, 2026 — court details verified by the Road Ready Safety editorial team against the City of El Paso and El Paso County municipal courts and Tex. Code Crim. Proc. ch. 45A.</p>
        </div>

      </div>
    </article>
  </TexasLayout>
) : (
  <meta http-equiv="refresh" content="0; url=/" />
)}
