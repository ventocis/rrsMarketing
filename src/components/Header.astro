---
const loginUrl = import.meta.env.VITE_LOGIN_URL || '';
---

<header class="w-full bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav class="max-w-[1152px] mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-8 h-20 w-full">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded flex-shrink-0" aria-label="Road Ready Safety — home">
      <img src="/assets/icons/texas/logo-shield.svg" alt="" class="h-[39.633px] w-9" width="36" height="40" />
      <div class="flex flex-col">
        <span class="text-[18px] font-bold text-[#1e2832] leading-[22.5px]" style="font-family: 'Outfit', sans-serif;">Road Ready</span>
        <span class="text-xs font-medium text-[#616d7b] leading-4" style="font-family: 'DM Sans', sans-serif;">Safety</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-8 flex-shrink-0">
      <a href="/#how-it-works" class="text-sm font-medium text-[#616d7b] hover:text-[#1e2832] transition-colors" style="font-family: 'DM Sans', sans-serif;">How It Works</a>
      <a href="/courses" class="text-sm font-medium text-[#616d7b] hover:text-[#1e2832] transition-colors" style="font-family: 'DM Sans', sans-serif;">Courses</a>
      <a href="/faq" class="text-sm font-medium text-[#616d7b] hover:text-[#1e2832] transition-colors" style="font-family: 'DM Sans', sans-serif;">FAQ</a>
      <a href="/support" class="text-sm font-medium text-[#616d7b] hover:text-[#1e2832] transition-colors" style="font-family: 'DM Sans', sans-serif;">Help Center</a>
    </div>

    <!-- Desktop buttons -->
    <div class="hidden md:flex items-center gap-3 flex-shrink-0">
      {loginUrl && (
        <a
          href={loginUrl}
          class="h-10 px-5 border border-[#e4e6ea] rounded-[10px] text-sm font-semibold text-[#1e2832] flex items-center justify-center hover:bg-[#f9fafb] transition-colors no-underline"
          style="font-family: 'DM Sans', sans-serif;"
        >
          Log In
        </a>
      )}
      <a
        href="/courses"
        class="bg-[#0667D1] hover:bg-[#0556b3] text-white pt-[11.6px] pb-[12.4px] px-[20px] rounded-[16px] text-sm font-semibold flex items-center justify-center leading-[20px] no-underline text-center transition-colors"
        style="font-family: 'DM Sans', sans-serif; min-height: 44px; box-shadow: 0 20px 25px -5px rgba(17,23,34,0.10), 0 8px 10px -6px rgba(17,23,34,0.05);"
      >
        Start Course
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-lg text-[#616d7b] hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#e5e5e5] bg-white">
    <div class="px-4 py-6 space-y-4">
      <a href="/#how-it-works" class="block text-lg font-medium text-[#1e2832] text-center py-2" style="font-family: 'DM Sans', sans-serif;">How It Works</a>
      <a href="/courses" class="block text-lg font-medium text-[#1e2832] text-center py-2" style="font-family: 'DM Sans', sans-serif;">Courses</a>
      <a href="/faq" class="block text-lg font-medium text-[#1e2832] text-center py-2" style="font-family: 'DM Sans', sans-serif;">FAQ</a>
      <a href="/support" class="block text-lg font-medium text-[#1e2832] text-center py-2" style="font-family: 'DM Sans', sans-serif;">Help Center</a>
      <div class="pt-4 space-y-3">
        {loginUrl && (
          <a
            href={loginUrl}
            class="block w-full h-12 px-4 rounded-[10px] text-[18px] font-semibold text-[#1e2832] border border-[#e5e5e5] bg-white hover:bg-gray-50 transition-colors text-center leading-[48px]"
            style="font-family: 'DM Sans', sans-serif;"
          >
            Log In
          </a>
        )}
        <a
          href="/courses"
          class="block w-full h-12 px-4 rounded-[10px] bg-[#0667D1] text-white text-[18px] font-semibold hover:bg-[#0556b3] transition-colors text-center leading-[48px]"
          style="font-family: 'DM Sans', sans-serif; box-shadow: 0 20px 25px -5px rgba(17,23,34,0.10), 0 8px 10px -6px rgba(17,23,34,0.05);"
        >
          Start Course
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Vanilla JS for mobile menu toggle — zero framework overhead -->
<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
