// Helper: join array or return 'Unavailable'
function joinOrNA(arr: string[] | undefined) {
  return arr && arr.length > 0 ? arr.join(', ') : 'Unavailable';
}
---

{!isEnabled && <meta http-equiv="refresh" content="0;url=/" />}

{isEnabled && (
<TexasLayout
  title={isEnhanced && courtSeoData[court.slug]
    ? courtSeoData[court.slug].title
    : `${court.county} County ${court.courtType} Court — ${court.courtName} | Driver Safety Course`}
  description={isEnhanced && courtSeoData[court.slug]
    ? courtSeoData[court.slug].description
    : `Complete your Texas Driver Safety Course for ${court.courtName} in ${court.county} County. Step-by-step instructions to dismiss your traffic ticket.`}
  keywords={`${court.courtName}, ${court.county} County, Texas driver safety course, defensive driving, traffic school`}
  url={`/texas/courts/${court.slug}`}
>

  {isEnhanced && (() => {
    const addr = court.address?.[0] ?? '';
    const addrParts = addr.split(',').map((s: string) => s.trim());
    const siteUrl = 'https://roadreadysafety.com';
    const courtCity = addrParts[1] || court.county;
    const schema = {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "GovernmentService",
          "name": `${court.courtName} — Texas Driver Safety Course (DSC)`,
          "description": `How to request and complete a Texas Driver Safety Course (defensive driving) to dismiss a traffic ticket at ${court.courtName} in ${court.county} County. Includes court fees, submission methods, required documents, and deadlines.`,
          "serviceType": "Driver Safety Course Request",
          "termsOfService": `${siteUrl}/texas/courts/${court.slug}`,
          "provider": {
            "@type": "GovernmentOrganization",
            "name": court.courtName,
            ...(court.phone?.[0] ? { "telephone": court.phone[0] } : {}),
            ...(court.email?.[0] ? { "email": court.email[0] } : {}),
            ...(court.website?.[0] ? { "url": court.website[0] } : {}),
            "address": {
              "@type": "PostalAddress",
              "streetAddress": addrParts[0] || undefined,
              "addressLocality": courtCity,
              "addressRegion": "TX",
              "addressCountry": "US"
            }
          },
          "areaServed": {
            "@type": "City",
            "name": `${courtCity}, Texas`
          },
          "url": `${siteUrl}/texas/courts/${court.slug}`
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Texas", "item": `${siteUrl}/texas` },
            { "@type": "ListItem", "position": 2, "name": "Texas Courts", "item": `${siteUrl}/texas/courts` },
            { "@type": "ListItem", "position": 3, "name": court.courtName, "item": `${siteUrl}/texas/courts/${court.slug}` }
          ]
        },
        (() => {
          const faq = (courtFaqData as any)[court.slug];
          if (!faq) return null;
          const questions: any[] = [];

          // Q1 — always present
          questions.push({
            "@type": "Question",
            "name": `Does ${court.courtName} accept defensive driving courses for ticket dismissal?`,
            "acceptedAnswer": { "@type": "Answer", "text": `Yes. ${court.courtName} accepts TDLR-approved Driver Safety Courses to dismiss eligible moving violations. You must request court approval before taking the course — do not enroll first.` }
          });

          // Q2 — how to submit
          if (faq.submissionMethods?.length) {
            const methods = faq.submissionMethods.join(', ');
            questions.push({
              "@type": "Question",
              "name": `How do I submit my DSC request to ${court.courtName}?`,
              "acceptedAnswer": { "@type": "Answer", "text": `You can submit your DSC request to ${court.courtName} ${methods.toLowerCase()}. Request approval before taking the course, then submit your completion documents using the same methods.` }
            });
          }

          // Q3 — required documents
          if (faq.requiredDocs?.length) {
            const docs = faq.requiredDocs.join('; ');
            questions.push({
              "@type": "Question",
              "name": `What documents do I need to submit to ${court.courtName} after completing defensive driving?`,
              "acceptedAnswer": { "@type": "Answer", "text": `After completing your course, submit the following to ${court.courtName}: ${docs}.` }
            });
          }

          // Q4 — fee
          questions.push({
            "@type": "Question",
            "name": `How much does ${court.courtName} charge for a Driver Safety Course?`,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": faq.feeKnown
                ? `${court.courtName} charges ${faq.fee} for a Driver Safety Course dismissal.`
                : `Fees are not currently posted online. Contact ${court.courtName} directly for current DSC court fees.`
            }
          });

          // Q5 — email accepted (only if definitive answer exists)
          if (faq.emailAccepted === true) {
            questions.push({
              "@type": "Question",
              "name": `Can I email my DSC documents to ${court.courtName}?`,
              "acceptedAnswer": { "@type": "Answer", "text": `Yes. ${court.courtName} accepts DSC documents by email.` }
            });
          } else if (faq.emailAccepted === false) {
            questions.push({
              "@type": "Question",
              "name": `Can I email my DSC documents to ${court.courtName}?`,
              "acceptedAnswer": { "@type": "Answer", "text": `No. ${court.courtName} does not accept DSC documents by email. Use the available submission methods: ${faq.submissionMethods?.join(', ') || 'contact the court for options'}.` }
            });
          } else if (faq.emailAccepted === 'application-only') {
            questions.push({
              "@type": "Question",
              "name": `Can I email my DSC documents to ${court.courtName}?`,
              "acceptedAnswer": { "@type": "Answer", "text": `Partially. ${court.courtName} accepts the DSC application by email, but the Certificate of Completion must be submitted by mail or in person — not by email.` }
            });
          }

          // Q6 — notarized affidavit (only if required)
          if (faq.requiresNotarizedAffidavit) {
            questions.push({
              "@type": "Question",
              "name": `Does ${court.courtName} require a notarized affidavit?`,
              "acceptedAnswer": { "@type": "Answer", "text": `Yes. ${court.courtName} requires a notarized DSC affidavit. You must have it notarized before submitting — many drivers miss this step and miss their deadline.` }
            });
          }

          // Q7 — Type 3A driving record (only if required)
          if (faq.requiresType3A) {
            questions.push({
              "@type": "Question",
              "name": `Does ${court.courtName} require a Type 3A driving record?`,
              "acceptedAnswer": { "@type": "Answer", "text": `Yes. ${court.courtName} requires a certified Type 3A driving record from the Texas Department of Public Safety (DPS). Order it at texas.gov before your submission deadline.` }
            });
          }

          // Q8 — always present
          questions.push({
            "@type": "Question",
            "name": `How long do I have to complete defensive driving after getting a ticket in ${court.courtName}?`,
            "acceptedAnswer": { "@type": "Answer", "text": `Texas law gives you 90 days from the date ${court.courtName} approves your DSC request to complete the course and submit your certificate. The clock starts on approval, not your citation date.` }
          });

          return { "@type": "FAQPage", "mainEntity": questions };
        })()
      ]
    };
    return <script type="application/ld+json" set:html={JSON.stringify(schema)} />;
  })()}

