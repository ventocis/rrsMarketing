                    <a href="https://www.victoriatx.gov/DocumentCenter/View/875/Drivers-Safety-Course-vs-Deferred-Disposition-PDF" target="_blank" rel="noopener noreferrer" class="bg-surface-muted border border-border rounded-[10px] p-4 flex items-center gap-3 no-underline hover:bg-gray-50 transition-colors group">
                      <svg class="w-[18px] h-[18px] shrink-0 text-primary" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 2.25H5.25A1.5 1.5 0 0 0 3.75 3.75v10.5a1.5 1.5 0 0 0 1.5 1.5h7.5a1.5 1.5 0 0 0 1.5-1.5V6.75L10.5 2.25z"/><polyline points="10.5 2.25 10.5 6.75 14.25 6.75"/></svg>
                      <span class="text-sm font-semibold text-primary group-hover:underline">Driving Safety Course vs. Deferred Disposition Comparison (PDF)</span>
