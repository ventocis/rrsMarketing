---
import TexasLayout from '../../layouts/TexasLayout.astro';
const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '/courses/tx-defensive';
const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

const faqs = [
  {
    "q": "How much does it cost to dismiss a ticket in Waco?",
    "a": "The court cost is typically up to about $144 ($169 in a school zone), set by each court — some McLennan County courts charge less (McGregor and Moody, for example, post $143.90). The TDLR-approved course is separate; ours is $28. Check your court's page for the exact amount."
  },
  {
    "q": "Can I take the Waco defensive driving course online?",
    "a": "Yes. Once the court approves your request, a TDLR-approved 6-hour course can be completed fully online. Every Waco-area court accepts a state-approved online course."
  },
  {
    "q": "My ticket is from Hewitt / Woodway / Robinson / Bellmead, not Waco. Does that change things?",
    "a": "The legal steps are the same, but you deal with that city's court — each with its own fee, request method, and deadlines. Open its page in the table above."
  },
  {
    "q": "How long do I have to finish?",
    "a": "Generally 90 days after the court approves the request. Request the course by your appearance date first, and don't pay the ticket — paying is a guilty plea and a conviction."
  },
  {
    "q": "Does a dismissal keep it off my insurance?",
    "a": "Yes. A driving safety course dismissal keeps the charge off your driving record under Texas law, so it can't raise your insurance — unlike paying, which is a conviction."
  }
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: "How to Dismiss a Traffic Ticket in Waco with Defensive Driving", description: "Dismiss a Waco-area traffic ticket: request a driving safety course by your appearance date, finish a 6-hour course in 90 days, submit your certificate. 'Waco' spans many McLennan County courts — here's how each differs.",
  author: { '@type': 'Organization', name: 'Road Ready Safety' },
  publisher: { '@type': 'Organization', name: 'Road Ready Safety', url: siteUrl },
  datePublished: '2026-06-13', dateModified: '2026-06-13',
  mainEntityOfPage: `${siteUrl}/texas/waco`,
});
const faqSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
});
---

{isEnabled ? (
  <TexasLayout title="How to Dismiss a Traffic Ticket in Waco with Defensive Driving (2026)" description="Dismiss a Waco-area traffic ticket: request a driving safety course by your appearance date, finish a 6-hour course in 90 days, submit your certificate. 'Waco' spans many McLennan County courts — here's how each differs." keywords="dismiss ticket waco, waco defensive driving, waco traffic ticket dismissal, driving safety course waco, mclennan county defensive driving, hewitt woodway robinson defensive driving" url="/texas/waco">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />

    <article class="bg-white pb-16 lg:pb-24">
      <div class="max-w-[880px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 lg:pt-14">

        <p class="text-sm text-text-body mb-6" style="font-family: 'DM Sans', sans-serif;">
          <a href="/texas" class="text-primary-deep font-medium hover:underline">Texas defensive driving</a>
          <span class="mx-2 text-text-subtle">›</span>
          <span class="text-text">Waco</span>
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-bold text-primary-navy leading-tight tracking-[-0.02em] mb-6" style="font-family: 'Outfit', sans-serif;">
          How to Dismiss a Traffic Ticket in Waco with Defensive Driving
        </h1>

        <div class="space-y-4 text-text-body text-base leading-7 mb-8" style="font-family: 'DM Sans', sans-serif;">
          <p><strong>Short answer:</strong> to dismiss a Waco-area traffic ticket, request a driving safety course from the court <strong>on or before your appearance date</strong>, complete a TDLR-approved 6-hour course within 90 days, and submit your certificate plus a certified DPS driving record. The charge is then dismissed and kept off your record.</p>
          <p><strong>The catch:</strong> a ticket "in Waco" might actually be at one of McLennan County's suburb or small-town courts — and each sets its own fee and process. Here's what's the same everywhere and how the local courts differ.</p>
        </div>

        <div class="bg-surface-muted border border-border rounded-xl p-5 mb-10">
          <p class="text-sm text-text-body" style="font-family: 'DM Sans', sans-serif;">This page is general information, not legal advice. Each court sets its own fees, deadlines, and procedures — confirm with the specific court on your citation. Road Ready Safety is a TDLR-licensed course provider, not a court.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">"Waco" isn't one court</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-10" style="font-family: 'DM Sans', sans-serif;">
          <p>Read the <strong>court name on your citation</strong>. The City of Waco runs its own court, but the surrounding cities each run theirs.</p>
          <p>Besides the <strong>City of Waco Municipal Court</strong>, McLennan County includes <strong>Bellmead, Lacy-Lakeview, Hewitt, Woodway, Robinson</strong> (the close-in suburbs) and smaller towns like <strong>McGregor, Lorena, Crawford, West, Mart, Moody, Riesel, Bruceville-Eddy, Beverly Hills, and Golinda</strong>. The city where you were stopped is your court.</p>
          <p>Tickets written by a <strong>constable or sheriff's deputy</strong> on county roads outside the city limits go to a <strong>McLennan County Justice of the Peace</strong> court. Same general process, different office.</p>
        </div>

        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">What's the same at every Waco-area court</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>Texas law sets the core rules, so the basic path to a dismissal is the same no matter which Waco-area court has your ticket:</p>
        </div>
        <div class="bg-surface-muted border border-border rounded-xl p-5 mb-10">
          <ul class="flex flex-col gap-2 list-none m-0 p-0 text-sm text-text-body">
            <li>• <strong>Request the course by your appearance/answer date</strong> — the date on your citation. Don't pay first: paying is a guilty plea and a conviction.</li>
            <li>• You need a <strong>valid Texas driver license and proof of insurance</strong>, and you plead guilty or no contest.</li>
            <li>• You can use it <strong>once every 12 months</strong>. It's <strong>not</strong> available for speeding 25+ mph over the limit (or 95+ mph), CDL holders, passing a school bus, or work-zone violations with workers present.</li>
            <li>• Court costs run <strong>up to about $144</strong> ($169 in a school zone) and are set by each court — some charge less.</li>
            <li>• After approval you have <strong>90 days</strong> to finish a TDLR-approved 6-hour course and submit the certificate plus a certified DPS <a href="/texas/type-3a-driving-record" class="text-primary-deep font-medium hover:underline">Type 3A driving record</a>.</li>
            <li>• Complete it and the charge is <strong>dismissed and kept off your record</strong> under Texas law (Code of Criminal Procedure ch. 45A) — it can't be used against you or raise your insurance.</li>
          </ul>
        </div>
        <div class="space-y-4 text-text-body text-base leading-7 mb-6" style="font-family: 'DM Sans', sans-serif;">
          <p>Want the full walkthrough? See <a href="/texas/speeding-ticket" class="text-primary-deep font-medium hover:underline">how Texas ticket dismissal works</a>, or <a href="/texas/eligibility-tracker" class="text-primary-deep font-medium hover:underline">check your eligibility</a>.</p>
        </div>
        <h2 class="text-2xl font-bold text-text mt-10 mb-4" style="font-family: 'Outfit', sans-serif;">How Waco-area courts differ</h2>
        <div class="space-y-4 text-text-body text-base leading-7 mb-4" style="font-family: 'DM Sans', sans-serif;">
          <p>The fee, how you request the course, the exact deadline, and small local rules vary court to court. Here are the 16 Waco-area courts we've researched — tap any one for its full instructions, fees, and contacts.</p>
        </div>
        <div class="overflow-x-auto my-2">
          <table class="w-full text-sm border-collapse" style="font-family: 'DM Sans', sans-serif;">
            <thead><tr class="border-b-2 border-border text-left"><th class="py-2 pr-4 font-semibold text-text">Waco-area court</th><th class="py-2 font-semibold text-text">What to know (tap to open the court page)</th></tr></thead>
            <tbody>
              <tr class="border-b border-border align-top">
                <td class="py-3 pr-4"><a href="/texas/courts/mclennan-municipal-waco" class="text-primary-deep font-semibold hover:underline">Waco Municipal Court</a></td>
