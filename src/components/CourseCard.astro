---
import { usd, hours, truncate } from '../utils/format';

interface Course {
  slug: string;
  state: string;
  course_name: string;
  course_type: string;
  language: string;
  duration_hours?: number;
  price_usd?: number | string;
  blurb?: string;
  description?: string;
  provider_type?: string;
  provider_name?: string;
  affiliate_link?: string;
  qa_link?: string;
}

interface Props {
  course: Course;
}

const { course } = Astro.props;

const portalUrl = import.meta.env.VITE_PORTAL_URL || 'https://app.roadreadysafety.com';
const isQa = import.meta.env.VITE_IS_QA === 'true';
const isTexasEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';
const TEXAS_SLUG = 'tx-defensive';

function getLearnMoreHref(slug: string) {
  if (isTexasEnabled && slug === TEXAS_SLUG) return '/texas';
  return `/courses/${slug}`;
}

function getSignUpHref(course: Course) {
  if (isQa && course.qa_link) return course.qa_link;
  if (course.provider_type === 'Partner' && course.affiliate_link) return course.affiliate_link;
  return portalUrl;
}

const isPartner = course.provider_type === 'Partner';
const signUpHref = getSignUpHref(course);
const learnMoreHref = getLearnMoreHref(course.slug);
---

<div class="bg-[#F9FAFB] rounded-[20px] p-6 flex flex-col justify-between h-full border border-[#e5e5e5] hover:shadow-md transition-shadow">
  <div>
    <h3 class="text-lg font-semibold text-[#1e2832] mb-3">{course.course_name}</h3>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 text-sm mb-3">
      {course.duration_hours && (
        <span class="rounded-md bg-white text-[#262626] border border-[#e5e5e5] px-2 py-1">{hours(course.duration_hours)}</span>
      )}
      {course.language && (
        <span class="rounded-md bg-white text-[#262626] border border-[#e5e5e5] px-2 py-1">
          {Array.isArray(course.language) ? course.language[0] : course.language}
        </span>
      )}
      {course.price_usd && (
        <span class="rounded-md bg-white text-[#262626] border border-[#e5e5e5] px-2 py-1">{usd(course.price_usd)}</span>
      )}
    </div>

    <p class="text-[#616d7b] leading-relaxed text-sm mb-3">
      {truncate(course.blurb || course.description, 140)}
    </p>

    {isPartner && course.provider_name && (
      <span class="mt-3 inline-flex max-w-max items-center gap-1 rounded-full border border-[#7cc3f9] bg-[#e6f4fd] px-3 py-1 text-xs font-semibold text-[#0667D1] leading-none">
        Provided by {course.provider_name}
      </span>
    )}
  </div>

  <!-- CTAs -->
  <div class="mt-5 flex flex-col gap-3 md:flex-row md:items-center">
    <a
      href={learnMoreHref}
      class="w-full text-center py-2.5 px-4 rounded-[12px] border border-[#e5e5e5] bg-white text-[#1e2832] text-sm font-semibold hover:bg-gray-50 transition-colors"
      style="font-family: 'DM Sans', sans-serif;"
    >
      Learn more
    </a>
    {isPartner ? (
      <a
        href={signUpHref}
        target="_blank"
        rel="noopener noreferrer"
        data-affiliate="true"
        class="w-full text-center py-2.5 px-4 rounded-[12px] bg-[#0667D1] hover:bg-[#0556b3] text-white text-sm font-semibold transition-colors"
        style="font-family: 'DM Sans', sans-serif; box-shadow: 0 4px 6px -1px rgba(6,103,209,0.2);"
      >
        Sign up
      </a>
    ) : (
      <a
        href={signUpHref}
        class="w-full text-center py-2.5 px-4 rounded-[12px] bg-[#0667D1] hover:bg-[#0556b3] text-white text-sm font-semibold transition-colors"
        style="font-family: 'DM Sans', sans-serif; box-shadow: 0 4px 6px -1px rgba(6,103,209,0.2);"
      >
        Sign up
      </a>
    )}
  </div>
</div>
