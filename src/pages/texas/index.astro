---
import TexasLayout from '../../layouts/TexasLayout.astro';

const isEnabled = import.meta.env.VITE_TEXAS_ROUTES_ENABLED === 'true';

const enrollUrl = import.meta.env.VITE_TEXAS_ENROLLMENT_URL || '#';
const contactUrl = import.meta.env.VITE_CONTACT_US_URL || '/contact';
---

{!isEnabled && (
  <meta http-equiv="refresh" content="0;url=/" />
)}

{isEnabled && (
<TexasLayout
  title="Dismiss Your Texas Traffic Ticket Online — $28 Total | Road Ready Safety"
  description="The easiest way to dismiss your Texas traffic ticket. TDLR-approved, all courts accepted. Download your free certificate instantly. 100% refund guaranteed."
  keywords="Texas driver safety course, defensive driving, traffic school, online course, Texas approved"
  url="/texas"
>

  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-[#e5f6fe] to-white pt-8 pb-16 lg:pt-16 lg:pb-[128px] relative overflow-hidden">
    <!-- Background blur effects -->
    <div class="absolute inset-0 opacity-30 pointer-events-none">
      <div class="absolute bg-[#7cc3f9] blur-[32px] rounded-full w-64 h-64 left-10 top-[150px]"></div>
      <div class="absolute bg-[#b9e2fe] blur-[32px] rounded-full w-96 h-96 bottom-20 right-10"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Hero - Two Column -->
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16 items-center justify-center">
        <!-- Left Column -->
        <div class="w-full lg:w-[544px] flex flex-col gap-[24px] items-center lg:items-start">
          <h1 class="text-[36px] lg:text-[60px] font-bold text-[#021954] leading-[36px] lg:leading-[74px] tracking-[-2px] text-center lg:text-left w-full max-w-[343px] lg:max-w-none">
            <span class="font-normal">#1</span> <span class="font-semibold">Texas Driver Safety Course:</span> <span class="font-normal">Fast, Convenient, &amp; Online</span>
          </h1>
          <p class="text-[18px] lg:text-xl text-[#616d7b] leading-[28px] lg:leading-7 max-w-[576px] text-center lg:text-left">
            Complete your Texas-approved 6-hour<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>defensive driving course from any<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>device. Dismiss your ticket or reduce<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>insurance rates &mdash; it&apos;s never been easier.
            <br />
            Get your certificate instantly after completing.
          </p>
          <div class="flex flex-col sm:flex-row gap-[16px] pt-[8px] w-full items-center lg:items-start">
            <a
              href={enrollUrl}
              class="bg-[#0667D1] hover:bg-[#0556b3] text-white h-[56px] px-[40px] rounded-[16px] shadow-[0px_20px_25px_-5px_rgba(17,23,34,0.10),0px_8px_10px_-6px_rgba(17,23,34,0.05)] text-[18px] font-semibold flex items-center justify-center leading-[28px] no-underline text-center w-full sm:w-auto"
              style="font-family: 'DM Sans', sans-serif;"
            >
              Start Course &mdash; $25
            </a>
            <a
              href="#pricing"
              class="bg-white border border-[#e4e6ea] text-[#1e2832] h-[56px] px-[40px] rounded-[16px] shadow-[0px_4px_6px_-1px_rgba(17,23,34,0.07),0px_2px_4px_-2px_rgba(17,23,34,0.05)] text-[18px] font-semibold flex items-center justify-center leading-[28px] no-underline text-center w-full sm:w-auto"
              style="font-family: 'DM Sans', sans-serif;"
            >
              Learn More
            </a>
          </div>
        </div>

        <!-- Right Column - Phone Mockup -->
        <div class="relative w-full lg:w-[544px] flex items-start justify-center lg:justify-end">
          <div class="relative w-full max-w-[240px] mx-auto lg:mx-0 scale-75 lg:scale-100">
            <!-- Phone Frame -->
            <div class="aspect-[320/675.55] bg-[#1e2832] rounded-[48px] p-2 shadow-[0px_25px_50px_-12px_rgba(0,0,0,0.25)]">
              <div class="bg-white rounded-[40px] h-full overflow-hidden">
                <!-- Status Bar -->
                <div class="bg-[#f0f2f4] h-8 flex items-center justify-center">
                  <div class="bg-[#1e2832] h-5 w-20 rounded-full"></div>
                </div>
                <!-- Phone Content -->
                <div class="p-4 space-y-4">
                  <div class="flex gap-2 items-center">
                    <div class="bg-[#03449e] rounded-xl w-8 h-8 flex-shrink-0"></div>
                    <div class="flex flex-col gap-1 flex-1">
                      <div class="bg-[#e5e8eb] border border-[#e4e6ea] h-3 rounded w-20"></div>
                      <div class="bg-[#f0f2f4] h-2 rounded w-14"></div>
                    </div>
                  </div>
                  <!-- Course Progress Card -->
                  <div class="bg-[#e5f6fe] rounded-2xl p-4 relative h-[84px]">
                    <p class="text-[#03449e] text-xs font-semibold mb-2">Course Progress</p>
                    <div class="absolute left-4 right-4 top-10 bg-[#7cc3f9] h-2 rounded-full overflow-hidden">
                      <div class="bg-[#0351b4] h-full w-1/3 rounded-full"></div>
                    </div>
                    <p class="absolute left-4 right-4 top-[52px] text-[#0351b4] text-xs">4 of 6 modules complete</p>
                  </div>
                  <!-- Module Items -->
                  <div class="space-y-2">
                    {[1, 2, 3].map((i) => (
                      <div class="bg-[#f9fafb] rounded-xl p-3 flex gap-3 items-center">
                        <div class={`rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 ${i <= 2 ? 'bg-[#0967d2]' : 'bg-[#e5e8eb] border border-[#e4e6ea]'}`}>
                          {i <= 2 && (
                            <img src="/assets/icons/texas/checkmark-white.svg" alt="" class="w-3 h-3" />
                          )}
                        </div>
                        <div class="bg-[#e5e8eb] border border-[#e4e6ea] h-2.5 rounded w-24 flex-1"></div>
                      </div>
                    ))}
                  </div>
                  <a
                    href={enrollUrl}
                    class="w-full bg-[#0667d1] text-white rounded-xl py-[14.8px] pb-[13.2px] text-sm font-semibold flex items-center justify-center leading-5 no-underline"
                  >
                    Continue Module
                  </a>
                </div>
              </div>
            </div>

            <!-- Floating Badge - Court Approved -->
            <div class="absolute bg-white rounded-2xl shadow-[0px_20px_25px_-5px_rgba(17,23,34,0.1),0px_8px_10px_-6px_rgba(17,23,34,0.05)] p-4 right-[-17px] top-16 flex gap-3 items-center">
              <div class="bg-[#e5f6fe] rounded-full w-10 h-10 flex items-center justify-center flex-shrink-0">
                <img src="/assets/icons/texas/check-circle.svg" alt="" class="w-5 h-5" />
              </div>
              <div>
                <p class="text-sm font-semibold text-[#1e2832] leading-5">Court Approved</p>
                <p class="text-xs text-[#616d7b] leading-4">All Texas courts</p>
              </div>
            </div>

            <!-- Floating Badge - Rating -->
            <div class="absolute bg-white rounded-2xl shadow-[0px_20px_25px_-5px_rgba(17,23,34,0.1),0px_8px_10px_-6px_rgba(17,23,34,0.05)] p-3 left-[-16px] bottom-[128px] flex flex-col gap-1">
              <div class="flex gap-2 items-center">
                <div class="flex gap-0.5">
                  {[...Array(5)].map((_, i) => (
                    <img src="/assets/icons/texas/star-rating.svg" alt="" class="w-4 h-4" />
                  ))}
                </div>
                <p class="text-sm font-semibold text-[#1e2832] leading-5">4.9/5</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Badges - 4 Column Horizontal Layout -->
      <div class="relative grid grid-cols-2 gap-6 lg:gap-8 mt-12 lg:mt-16 justify-center items-center md:flex md:flex-row">
        <!-- Vector decorations -->
        <div class="absolute left-[calc(25%-68px+12px)] top-[31.65px] w-[136px] h-4 hidden lg:block z-0">
          <img src="/assets/icons/texas/vector-decoration-features.svg" alt="" class="w-full h-full" />
        </div>
        <div class="absolute left-[calc(50%-68px+12px)] top-[55.65px] w-[136px] h-4 hidden lg:block z-0 transform scale-y-[-1]">
          <img src="/assets/icons/texas/vector-decoration-features.svg" alt="" class="w-full h-full" />
        </div>
        <div class="absolute left-[calc(75%-68px+12px)] top-[31.65px] w-[136px] h-4 hidden lg:block z-0">
          <img src="/assets/icons/texas/vector-decoration-features.svg" alt="" class="w-full h-full" />
        </div>

        <!-- TDLR-Approved -->
        <div class="relative flex-1 max-w-[282px] w-full flex flex-col gap-6 items-center px-3 py-8 rounded-[20px]">
          <div class="relative flex items-center justify-center w-[78px] h-[80px]">
            <div class="absolute inset-0 border border-[#e8e8e8] rounded-2xl"></div>
            <div class="relative w-10 h-10 flex items-center justify-center z-10 py-5">
              <img src="/assets/icons/texas/tdlr-approved-icon.svg" alt="" class="w-10 h-10" />
            </div>
          </div>
          <div class="flex flex-col gap-3 items-center w-full max-md:text-center">
            <h3 class="text-2xl font-semibold text-[#151515] leading-[32px] max-md:text-center">TDLR- Approved</h3>
            <p class="text-sm text-[#4a5565] leading-5 text-center">
              State-certified course accepted by all<br />
              Texas courts
            </p>
          </div>
        </div>

        <!-- Mobile Friendly -->
        <div class="relative flex-1 max-w-[282px] w-full flex flex-col gap-6 items-center px-3 py-8 rounded-[20px]">
          <div class="relative flex items-center justify-center w-[78px] h-[80px]">
            <div class="absolute inset-0 border border-[#e8e8e8] rounded-2xl"></div>
            <div class="relative w-10 h-10 flex items-center justify-center z-10 py-5">
              <img src="/assets/icons/texas/mobile-friendly-icon.svg" alt="" class="w-10 h-10" />
            </div>
          </div>
          <div class="flex flex-col gap-3 items-center w-full max-md:text-center">
            <h3 class="text-2xl font-semibold text-[#151515] leading-[32px] max-md:text-center">Mobile Friendly</h3>
            <p class="text-sm text-[#4a5565] leading-5 text-center">
              Complete on any device - phone,<br />
              tablet, or computer
            </p>
          </div>
        </div>

        <!-- Super Easy -->
        <div class="relative flex-1 max-w-[282px] w-full flex flex-col gap-6 items-center px-3 py-8 rounded-[20px]">
          <div class="relative flex items-center justify-center w-[78px] h-[80px]">
            <div class="absolute inset-0 border border-[#e8e8e8] rounded-2xl"></div>
            <div class="relative w-10 h-10 flex items-center justify-center z-10 py-5">
              <img src="/assets/icons/texas/super-easy-icon.svg" alt="" class="w-10 h-10" />
            </div>
          </div>
          <div class="flex flex-col gap-3 items-center w-full max-md:text-center">
            <h3 class="text-2xl font-semibold text-[#151515] leading-[32px] max-md:text-center">Super Easy</h3>
            <p class="text-sm text-[#4a5565] leading-5 text-center">
              Simple lessons, unlimited quiz<br />
              attempts, auto-save progress
            </p>
          </div>
        </div>

        <!-- 100% Guarantee -->
        <div class="relative flex-1 max-w-[282px] w-full flex flex-col gap-6 items-center px-3 py-8 rounded-[20px]">
          <div class="relative flex items-center justify-center w-[78px] h-[80px]">
            <div class="absolute inset-0 border border-[#e8e8e8] rounded-2xl"></div>
            <div class="relative w-10 h-10 flex items-center justify-center z-10 py-5">
              <img src="/assets/icons/texas/guarantee-icon.svg" alt="" class="w-10 h-10" />
            </div>
          </div>
          <div class="flex flex-col gap-3 items-center w-full max-md:text-center">
            <h3 class="text-2xl font-semibold text-[#151515] leading-[32px] max-md:text-center">100% Guarantee</h3>
            <p class="text-sm text-[#4a5565] leading-5 text-center">
              Not a fit? Get a full refund before you complete the course.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Course Info + Pricing Card -->
  <section id="pricing" class="py-16 lg:py-[112px] bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-20 items-start justify-center">
        <!-- Left Column -->
        <div class="flex flex-col gap-[24px] items-start w-full lg:w-[536px] pb-8 lg:pb-0">
          <div class="bg-[#e5f6fe] inline-flex items-center px-4 py-2 rounded-full">
            <span class="text-sm font-semibold text-[#0351b4] leading-5">Dismiss Your Texas Traffic Ticket Online</span>
          </div>
          <h2 class="text-[30px] lg:text-[48px] font-bold text-[#1e2832] leading-[36px] lg:leading-[48px] tracking-[-0.75px] lg:tracking-[-1.2px]">
            Texas Defensive Driving<br />
            <span class="text-[#03449e]">Course (6 hr)</span>
          </h2>
          <p class="text-[18px] lg:text-lg text-[#616d7b] leading-[28px] lg:leading-7">
            Everything you need to dismiss your<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>Texas traffic ticket or<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>reduce insurance<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>premiums. State-approved, court-<br class="lg:hidden" />
            <span class="hidden lg:inline"> </span>accepted, and designed for busy Texans.
          </p>
          <!-- Feature List -->
          <div class="flex flex-col gap-[16px] w-full pt-[8px]">
            {[
              '6-Hour State-Approved Course',
              'Instant Digital Certificate',
              'Mobile & Desktop Access',
              'Automatic Progress Saving',
              'Unlimited Quiz Attempts',
              'Customer Support',
            ].map((feature) => (
              <div class="flex gap-[12px] items-center">
                <div class="bg-[#e5f6fe] rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0">
                  <img src="/assets/icons/texas/checkmark-feature.svg" alt="" class="w-3.5 h-3.5" />
                </div>
                <span class="text-[16px] font-medium text-[#1e2832] leading-[24px]">{feature}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right Column - Pricing Card -->
        <div class="bg-white border border-[#e4e6ea] rounded-[20px] shadow-[0px_1px_3px_0px_rgba(17,23,34,0.04),0px_6px_16px_0px_rgba(17,23,34,0.06)] p-[34px] lg:sticky lg:top-0 w-full lg:w-[536px] h-auto lg:h-[520px] flex flex-col">
          <!-- Price -->
          <div class="mb-2">
            <div class="flex items-baseline gap-2">
              <span class="text-[48px] font-bold text-[#1e2832] leading-[48px]">$25</span>
              <span class="text-base text-[#616d7b] leading-6">.00</span>
              <span class="text-2xl font-medium text-[#616d7b] leading-[48px] line-through ml-4">$35.00</span>
            </div>
          </div>
          <div class="text-sm text-[#616d7b] leading-5 mb-4">+ $3.00 state processing fee</div>

          <!-- Star Rating -->
          <div class="flex gap-3 items-center pb-6 pt-4 mb-6">
            <div class="flex gap-0">
              {[...Array(5)].map((_, i) => (
                <img src="/assets/icons/texas/star-pricing.svg" alt="" class="w-5 h-5" />
              ))}
            </div>
            <span class="text-sm font-medium text-[#1e2832] leading-5">4.9 out of 5</span>
          </div>

          <!-- Enroll Button -->
          <a
            href={enrollUrl}
            class="w-full h-[56px] bg-[#0667d1] hover:bg-[#0556b3] text-white rounded-2xl shadow-[0px_10px_15px_-3px_rgba(17,23,34,0.08),0px_4px_6px_-4px_rgba(17,23,34,0.05)] text-lg font-semibold flex items-center justify-center gap-2 mb-6 no-underline"
          >
            Start Course &mdash; $25
            <img src="/assets/icons/texas/arrow-enroll.svg" alt="" class="w-4 h-4" />
          </a>

          <!-- Trust Indicators -->
          <div class="flex flex-col gap-3 pt-4">
            <div class="flex gap-2 items-center">
              <img src="/assets/icons/texas/secure-checkout-icon.svg" alt="" class="w-4 h-4" />
              <span class="text-sm text-[#616d7b] leading-5">Secure checkout</span>
            </div>
            <div class="flex gap-2 items-center">
              <img src="/assets/icons/texas/tdlr-provider-icon.svg" alt="" class="w-4 h-4" />
              <span class="text-sm text-[#616d7b] leading-5">TDLR-approved provider</span>
            </div>
            <div class="flex gap-2 items-center">
              <img src="/assets/icons/texas/money-back-icon.svg" alt="" class="w-4 h-4" />
              <span class="text-sm text-[#616d7b] leading-5">100% risk-free guarantee</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect Accordion -->
  <section class="py-16 lg:py-24 bg-gradient-to-b from-[#f9fafb] to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="flex flex-col gap-4 items-center mb-12">
        <h2 class="text-4xl lg:text-[48px] font-bold text-[#101828] text-center leading-[48px]">
          What to Expect
        </h2>
        <p class="text-lg text-[#4a5565] text-center leading-7">
          Everything you need to know about the Texas defensive driving process
        </p>
      </div>

      <!-- Accordion Items -->
      <div class="flex flex-col gap-4">

        <!-- Texas Requirements -->
        <details class="group bg-white rounded-2xl overflow-hidden border border-[#e5e7eb] shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1),0px_1px_2px_-1px_rgba(0,0,0,0.1)] open:border-2 open:border-[#03449e] open:shadow-[0px_10px_15px_-3px_rgba(0,0,0,0.1),0px_4px_6px_-4px_rgba(0,0,0,0.1)]">
          <summary class="w-full h-[100px] relative rounded-2xl cursor-pointer list-none flex items-center">
            <div class="absolute left-8 top-6 flex gap-4 items-center">
              <div class="bg-[#f9fafb] group-open:bg-[#e5f6fe] rounded-2xl w-12 h-12 flex items-center justify-center transition-colors">
                <img src="/assets/icons/texas/texas-requirements-active.svg" alt="" class="w-6 h-6" />
              </div>
              <div class="flex flex-col gap-1 items-start">
                <h3 class="text-xl font-bold text-[#101828] leading-7">Texas Requirements</h3>
                <p class="text-sm text-[#4a5565] leading-5">Everything Texas law requires for ticket dismissal</p>
              </div>
            </div>
            <div class="absolute right-8 top-6 w-4 h-4 flex items-center justify-center">
              <img src="/assets/icons/texas/chevron-down.svg" alt="" class="w-4 h-4 transition-transform group-open:rotate-180" />
            </div>
          </summary>
          <div class="px-8 pb-6 pt-0">
            <div class="bg-[#fafafa] border border-[#e4e6ea] rounded-2xl p-6 flex flex-col gap-6">
              <p class="text-sm text-[#364153] leading-6 mb-2">
                Texas doesn't just say "take a course." To dismiss a ticket with defensive driving, most Texas courts require you to:
              </p>
              <div class="flex flex-col gap-4">
                <!-- Be Eligible -->
                <div class="bg-white border border-[#f3f4f6] rounded-[10px] p-4">
                  <div class="flex gap-3 items-start">
                    <div class="pt-0.5 flex-shrink-0">
                      <img src="/assets/icons/texas/requirement-check-clipboard.svg" alt="" class="w-[18px] h-[18px]" />
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <h4 class="text-sm font-bold text-[#101828] leading-5 mb-1">Be Eligible</h4>
                      <p class="text-sm text-[#4a5565] leading-5">In general, you must not hold a commercial driver license, must not have been going 25 mph or more over the posted limit, and you usually can't have taken a Texas defensive driving course for ticket dismissal in the last 12 months.</p>
                    </div>
                  </div>
                </div>
                <!-- Get Permission -->
                <div class="bg-white border border-[#f3f4f6] rounded-[10px] p-4">
                  <div class="flex gap-3 items-start">
                    <div class="pt-0.5 flex-shrink-0">
                      <img src="/assets/icons/texas/requirement-check-clipboard.svg" alt="" class="w-[18px] h-[18px]" />
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <h4 class="text-sm font-bold text-[#101828] leading-5 mb-1">Get Permission</h4>
                      <p class="text-sm text-[#4a5565] leading-5">Before your deadline, your judge or court clerk must approve you to take a 6-hour state-approved defensive driving course for ticket dismissal.</p>
                    </div>
                  </div>
                </div>
                <!-- Complete a Course -->
                <div class="bg-white border border-[#f3f4f6] rounded-[10px] p-4">
                  <div class="flex gap-3 items-start">
                    <div class="pt-0.5 flex-shrink-0">
                      <img src="/assets/icons/texas/requirement-check-clipboard.svg" alt="" class="w-[18px] h-[18px]" />
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <h4 class="text-sm font-bold text-[#101828] leading-5 mb-1">Complete a Course</h4>
                      <p class="text-sm text-[#4a5565] leading-5">You must finish every lesson, pass the required quizzes, and certify that you&mdash;not someone else&mdash;completed the course.</p>
                    </div>
                  </div>
                </div>
                <!-- Get a Copy of Your Driving Record -->
                <div class="bg-white border border-[#f3f4f6] rounded-[10px] p-4">
                  <div class="flex gap-3 items-start">
                    <div class="pt-0.5 flex-shrink-0">
                      <img src="/assets/icons/texas/requirement-check-clipboard.svg" alt="" class="w-[18px] h-[18px]" />
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <h4 class="text-sm font-bold text-[#101828] leading-5 mb-1">Get a Copy of Your Driving Record</h4>
                      <p class="text-sm text-[#4a5565] leading-5">Many Texas courts require a copy of your 3A driving record along with your course certificate.</p>
                    </div>
                  </div>
                </div>
                <!-- Turn Everything In -->
                <div class="bg-white border border-[#f3f4f6] rounded-[10px] p-4">
                  <div class="flex gap-3 items-start">
                    <div class="pt-0.5 flex-shrink-0">
                      <img src="/assets/icons/texas/requirement-check-clipboard.svg" alt="" class="w-[18px] h-[18px]" />
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <h4 class="text-sm font-bold text-[#101828] leading-5 mb-1">Turn Everything In</h4>
                      <p class="text-sm text-[#4a5565] leading-5">You'll submit your Certificate of Course Completion to the court by the deadline they give you.</p>
                    </div>
                  </div>
                </div>
              </div>
              <p class="text-sm text-[#364153] leading-6 mt-2">
