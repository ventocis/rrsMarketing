---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import blogData from '../../data/blog.json';

export function getStaticPaths() {
  const posts = (blogData as any).posts ?? [];
  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: {
    slug: string;
    title: string;
    date: string;
    description: string;
    tags?: string[];
    content: string;
  };
}

const { post } = Astro.props;
const htmlContent = marked(post.content) as string;

const siteUrl = import.meta.env.VITE_SITE_URL || 'https://roadreadysafety.com';

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.date,
  url: `${siteUrl}/blog/${post.slug}`,
  publisher: {
    '@type': 'Organization',
    name: 'Road Ready Safety',
    url: siteUrl,
  },
});
---

<Layout
  title={post.title}
  description={post.description}
  keywords={`driving tips, traffic safety, ${post.tags?.join(', ') ?? 'defensive driving'}`}
  url={`/blog/${post.slug}`}
>
  <script type="application/ld+json" set:html={articleSchema} />
  <Header />

  <main class="bg-white min-h-screen">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 py-8 md:py-16">

      <!-- Back nav -->
      <nav class="mb-8">
        <a
          href="/blog"
          class="inline-flex items-center text-primary hover:text-primary-hover font-medium transition-colors"
          style="font-family: 'DM Sans', sans-serif;"
        >
          <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>
      </nav>

      <!-- Article header -->
      <header class="mb-10">
        <time
          class="text-sm text-text-body block mb-4"
          datetime={post.date}
          style="font-family: 'DM Sans', sans-serif;"
        >
          {formatDate(post.date)}
        </time>
        <h1
          class="text-3xl md:text-4xl font-bold text-text mb-4 leading-tight"
          style="font-family: 'Outfit', sans-serif;"
        >
          {post.title}
        </h1>
        <p
          class="text-xl text-text-body leading-relaxed"
          style="font-family: 'DM Sans', sans-serif;"
        >
          {post.description}
        </p>
      </header>

      <!-- Article body — styled via is:global since @tailwindcss/typography is not installed -->
      <article class="blog-content" set:html={htmlContent} />

      <!-- Footer nav -->
      <footer class="mt-12 pt-8 border-t border-border">
        <a
          href="/blog"
          class="inline-flex items-center text-primary hover:text-primary-hover font-medium transition-colors"
          style="font-family: 'DM Sans', sans-serif;"
        >
          <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>
      </footer>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Blog post body — mirrors DocLayout styling */
  .blog-content { font-family: 'DM Sans', sans-serif; }

  .blog-content h1, .blog-content h2, .blog-content h3,
  .blog-content h4, .blog-content h5, .blog-content h6 {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    color: #1e2832;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .blog-content h1 { font-size: 1.875rem; margin-top: 0; margin-bottom: 1rem; }
  .blog-content h2 {
    font-size: 1.375rem; margin-top: 2.5rem; margin-bottom: 0.75rem;
    padding-bottom: 0.5rem; border-bottom: 1px solid #e4e6ea;
  }
  .blog-content h3 { font-size: 1.125rem; margin-top: 2rem; margin-bottom: 0.5rem; }

  .blog-content p  { font-size: 0.9375rem; line-height: 1.75; color: #616d7b; margin-bottom: 1.25rem; }
  .blog-content strong { color: #1e2832; font-weight: 600; }
  .blog-content em   { color: #616d7b; }

  .blog-content ul, .blog-content ol {
    color: #616d7b; font-size: 0.9375rem; line-height: 1.75;
    padding-left: 1.5rem; margin-bottom: 1.25rem;
  }
  .blog-content ul { list-style-type: disc; }
  .blog-content ol { list-style-type: decimal; }
  .blog-content li { margin-bottom: 0.375rem; }

  .blog-content a { color: #0667D1; text-decoration: underline; text-underline-offset: 2px; }
  .blog-content a:hover { color: #0556b3; }

  .blog-content hr { border: none; border-top: 1px solid #e4e6ea; margin: 2.5rem 0; }

  .blog-content blockquote {
    border-left: 3px solid #0667D1; padding-left: 1rem;
    margin: 1.5rem 0; color: #616d7b; font-style: italic;
  }

  .blog-content code {
    background: #f3f4f6; border-radius: 4px;
    padding: 0.125rem 0.375rem; font-size: 0.875rem; color: #1e2832;
  }
</style>
